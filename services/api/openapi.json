            "type": "string"
          },
          "status": {
            "title": "Status",
            "type": "string"
          },
          "version": {
            "title": "Version",
            "type": "string"
          }
        },
        "required": [
          "status",
          "version",
          "git_sha"
        ],
        "title": "HealthResponse",
        "type": "object"
      },
      "ListEnvelope": {
