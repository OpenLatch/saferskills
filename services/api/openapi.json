    "/api/v1/scans": {
      "get": {
        "description": "Slim summary list \u2014 JOINs scans + catalog_items, projects ScanReportSummary.",
        "operationId": "list_scans_api_v1_scans_get",
        "parameters": [
          {
            "in": "query",
            "name": "source",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "enum": [
                    "submission",
                    "ingestion",
                    "rescan_drift",
                    "rescan_appeal"
                  ],
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Source"
            }
