            "type": "integer"
          },
          "author": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Author"
          },
          "findings_count": {
            "default": 0,
            "title": "Findings Count",
            "type": "integer"
          },
          "github_url": {
            "title": "Github Url",
            "type": "string"
          },
          "id": {
            "title": "Id",
            "type": "string"
          },
