# SaferSkills API — environment variables.
# Copy to `.env` for local dev. `services/api/app/core/config.py` is the
# canonical source of truth — every var below maps to a Settings field.

# Environment tier — drives Sentry env tag, log format, migration auto-run.
ENV=development
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://postgres:dev@localhost:5432/saferskills_dev

# Comma-separated allow-list for the FastAPI CORS middleware. With the webapp's
# same-origin /api/* reverse proxy the browser never calls cross-origin, so CORS
# is exercised only by direct/tooling callers.
CORS_ALLOWED_ORIGINS=http://localhost:4321,http://localhost:5173

# Shared secret proving a request came from the trusted same-origin webapp proxy.
# When set, the per-IP rate limiter trusts the forwarded visitor IP only on
# requests carrying a matching `X-Proxy-Secret` header — so a direct caller to
# the public API cannot spoof X-Forwarded-For to dodge the cap. Must equal the
# webapp's SAFERSKILLS_PROXY_SHARED_SECRET. Empty (dev/test) → the raw TCP peer.
SAFERSKILLS_PROXY_SHARED_SECRET=

# Observability (all optional — empty disables)
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
POSTHOG_PROJECT_KEY=

# Build identity (injected by CI on prod images)
GIT_SHA=local
VERSION=0.0.0-foundation

# Scan engine identity (rubric/ subtree SHA + engine commit SHA). The build
# pipeline stamps both; for local dev they default to GIT_SHA / "unknown".
RUBRIC_VERSION=
ENGINE_VERSION=

# Optional GitHub PAT for tarball fetches + the hourly /stats github_stars
# proxy — without it the 60 req/h anonymous limit applies; with it, 5,000 req/h.
GITHUB_TOKEN=

# Maximum scan submissions per IP per 24h window (D-FE-11). Shared by
# POST /scans and POST /scans/upload. Loopback callers are exempt.
SCAN_SUBMIT_DAILY_LIMIT=10

# Public webapp origin — builds the unlisted share_url + upload source registryUrl.
PUBLIC_BASE_URL=http://localhost:4321

# Maximum unlisted-run lookups (GET /scans/r/{token}) per IP per 24h. Loopback exempt.
PRIVATE_LOOKUP_DAILY_LIMIT=60

# Direct-upload limits (POST /scans/upload). Body cap is enforced while streaming.
UPLOAD_MAX_BYTES=10485760
# Uploaded-.zip extraction guards (per-file / total / ratio / entry-count).
UPLOAD_EXTRACT_MAX_PER_FILE_BYTES=5242880
UPLOAD_EXTRACT_MAX_TOTAL_BYTES=52428800
UPLOAD_EXTRACT_MAX_RATIO=100
UPLOAD_EXTRACT_MAX_ENTRIES=1000
# Comma-separated upload extension allowlist.
UPLOAD_ALLOWED_EXTENSIONS=.zip,.md,.json,.yaml,.yml,.toml,.txt,.js,.ts,.py,.sh

# Unlisted-run TTL (sets scan_runs.expires_at) + upload re-scan window, in days.
UNLISTED_RETENTION_DAYS=90
UPLOAD_RESCAN_WINDOW_DAYS=90
# In-process expiry-sweep loop interval (advisory lock 0x5AFE5C12).
SWEEP_INTERVAL_SECONDS=3600

# Maximum stored-snapshot .zip downloads per IP per 24h window. Loopback callers
# (trusted local seeding) are exempt. Artifact bytes live in-Postgres
# (artifact_blobs, content-addressed) — no new store / secret.
ARTIFACT_DOWNLOAD_DAILY_LIMIT=200

# HS256 signing key for the short-lived vendor right-of-reply session JWT
# (`ss_vendor_session` cookie). MUST be a 32+ byte random string in prod;
# rotate quarterly. The default below is dev-only and insecure.
VENDOR_SESSION_SECRET=dev-insecure-vendor-session-secret-change-me

# Cloudflare Turnstile siteverify secret for the scan-submit human gate. Empty
# → the gate is bypassed (dev/test only — the startup guard HARD-FAILS boot if
# this is empty when ENV=staging|production). In non-prod use Cloudflare's
# always-pass test secret: 1x0000000000000000000000000000000AA
TURNSTILE_SECRET_KEY=<set-me>

# ── Ingestion (I-04 Phase A) ────────────────────────────────────────────
# Start the in-process Procrastinate ingestion worker in the FastAPI lifespan
# (advisory lock 0x5AFE5C13). Live external cadence still needs the GitHub App
# creds below; with the flag on but creds unset, cron adapters log + no-op.
INGESTION_WORKER_ENABLED=true
# Worker concurrency. INVARIANT: keep below db pool_size+max_overflow (30).
INGESTION_WORKER_CONCURRENCY=4
# GitHub App `saferskills-ingest` (founder action; outbox 01). PEM is multi-line —
# use base64 in a Fly secret. Local dev reads from this gitignored .env.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=
GITHUB_WEBHOOK_SECRET=
# Hishel RFC-9111 cache (Fly volume /data mount; outbox 04).
HISHEL_DB_PATH=/data/.hishel.db
HISHEL_MAX_SIZE_BYTES=524288000
HISHEL_GITHUB_TTL_SECONDS=86400
HISHEL_AGGREGATOR_TTL_SECONDS=3600
# Comma-separated source names disabled in this env (e.g. "mcp_so").
INGESTION_SOURCE_BLOCKLIST=
# Enable the github_topics code-search discovery pass (D-04-35). Default off in A1.
INGESTION_GITHUB_CODE_SEARCH_ENABLED=false
# Slack incoming-webhook for #saferskills-alerts (Phase C; outbox 03).
SLACK_ALERTS_WEBHOOK_URL=
