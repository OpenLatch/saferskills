{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": {
    "includes": [
      "**",
      "!**/generated",
      "!services/api/openapi.json",
      "!**/dist",
      "!**/node_modules",
      "!**/.pnpm-store",
      "!**/.venv",
      "!**/routeTree.gen.ts",
      "!**/.planning",
      "!**/.claude",
      "!**/.local",
      "!**/*.astro",
      "!**/*.mdx",
      "!schemas",
      "!webapp/public",
      "!services/api/app/templates",
      "!ui",
      "!cli/tests/fixtures"
    ]
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": { "noNonNullAssertion": "warn" }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "trailingCommas": "es5",
      "semicolons": "asNeeded",
      "quoteStyle": "single"
    }
  }
}
