---
/**
 * SaferSkills S-monogram logo.
 *
 * Renders the locked SVG asset from `/logos/` — served by `webapp/public/logos/`
 * in production and mirrored at `ui/public/logos/` so Ladle stories load the
 * same brand asset. Source-of-truth lives in `ui/docs/brand-assets/`.
 * The default `saferskills-logo.svg` is the two-tone teal monogram per the
 * Wordmark Spec lock 2026-05-27. For surfaces that need a single-color render
 * (badge SVG endpoint, README), use the matching `-bw.svg` / `-light-logo.svg`.
 */
interface Props {
  size?: number
  mono?: 'ink' | 'paper' | 'primary' | null
  class?: string
  ariaLabel?: string
}
const { size = 24, mono = null, class: className = '', ariaLabel } = Astro.props

const src =
  mono === 'paper'
    ? '/logos/saferskills-light-logo.svg'
    : mono === 'ink'
      ? '/logos/saferskills-logo-bw.svg'
      : '/logos/saferskills-logo.svg'
---
<img
  src={src}
  alt={ariaLabel ?? ''}
  aria-hidden={ariaLabel ? undefined : 'true'}
  width={size}
  height={size}
  class={`ss-logo ${className}`.trim()}
  loading="eager"
  decoding="async"
/>

<style>
  .ss-logo {
    display: inline-block;
    flex-shrink: 0;
  }
</style>
