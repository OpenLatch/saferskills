---
/**
 * SaferSkills footer.
 *
 * Dark slate + diag-hatching texture (D-FE-05 / D-FE-36). 5-column grid:
 * brand col (44px wordmark + lead + ft-meta + ThemeToggle) + 4 link cols
 * (SCORES / AGENTS / DOCS / PROJECT, labels per D-FE-27).
 *
 * Footer attribution to OpenLatch is the ONLY catalog surface that names
 * OpenLatch (anti-recommendation rule — see .claude/rules/design-system.md).
 */
import ThemeToggle from './ThemeToggle.tsx'

const cols = [
  {
    label: 'SCORES',
    links: [
      { label: 'All skills', href: '/catalog' },
      { label: 'Trending', href: '/catalog?sort=trending' },
      { label: 'Top-flagged', href: '/catalog?sort=flagged' },
      { label: 'MCP servers', href: '/catalog?kind=mcp_server' },
      { label: 'Skills', href: '/catalog?kind=skill' },
    ],
  },
  {
    label: 'AGENTS',
    links: [
      { label: 'Claude Code', href: '/agents/claude-code' },
      { label: 'Cursor', href: '/agents/cursor' },
      { label: 'Codex', href: '/agents/codex' },
      { label: 'Copilot', href: '/agents/copilot' },
      { label: 'Windsurf', href: '/agents/windsurf' },
    ],
  },
  {
    label: 'DOCS',
    links: [
      { label: 'Overview', href: '/docs' },
      { label: 'CLI', href: '/docs#cli' },
      { label: 'API', href: '/docs#api' },
      { label: 'Methodology', href: '/methodology' },
      { label: 'Detection rules', href: '/methodology#rules' },
    ],
  },
  {
    label: 'PROJECT',
    links: [
      { label: 'About', href: '/about' },
      { label: 'Contact', href: '/about#reach-us' },
      { label: 'Privacy', href: '/privacy' },
      { label: 'Cookie policy', href: '/cookies' },
      { label: 'GitHub', href: 'https://github.com/OpenLatch/saferskills', external: true },
    ],
  },
]
---
<footer class="footer">
  <div class="container">
    <div class="ft-top">
      <div class="ft-brand">
        <span class="word">
          <img
            class="mk"
            src="/logos/saferskills-logo-animated.svg"
            alt=""
            aria-hidden="true"
          />
          SaferSkills
        </span>
        <p>
          Independent, transparent, open-source scoring for AI skills, MCPs, and plugins.
        </p>
        <p class="ft-meta">
          Stewarded by <a href="https://openlatch.ai" rel="noopener">OpenLatch</a>
        </p>
        <ThemeToggle client:idle />
      </div>
      {cols.map((col) => (
        <div class="ft-col">
          <h6>{col.label}</h6>
          <ul>
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  rel={link.external ? 'noopener' : undefined}
                  target={link.external ? '_blank' : undefined}
                >{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</footer>
