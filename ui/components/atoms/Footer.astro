---
/**
 * SaferSkills footer.
 *
 * Dark slate + diag-hatching texture. 5-column grid:
 * brand col (44px wordmark + lead + ft-meta + ThemeToggle) + 4 link cols
 * (SCORES / AGENTS / DOCS / PROJECT).
 *
 * Footer attribution to OpenLatch is the ONLY catalog surface that names
 * OpenLatch (anti-recommendation rule — see .claude/rules/design-system.md).
 */
import ThemeToggle from './ThemeToggle.tsx'

const cols = [
  {
    label: 'SCORES',
    links: [
      { label: 'All skills', href: '/capabilities' },
      { label: 'Trending', href: '/capabilities?sort=trending' },
      { label: 'Top-flagged', href: '/capabilities?sort=flagged' },
      { label: 'MCP servers', href: '/capabilities?kind=mcp_server' },
      { label: 'Skills', href: '/capabilities?kind=skill' },
    ],
  },
  {
    label: 'AGENTS',
    links: [
      // The per-agent install guides live in the docs IA at
      // /docs/install/per-agent-guides/<id>/ (the `/agents*` app namespace is the
      // Agent Report + directory, NOT install docs). Keep these in lockstep with
      // the docs IA — the docs-build internal-link gate covers the docs side.
      { label: 'Claude Code', href: '/docs/install/per-agent-guides/claude-code/' },
      { label: 'Cursor', href: '/docs/install/per-agent-guides/cursor/' },
      { label: 'Codex', href: '/docs/install/per-agent-guides/codex/' },
      { label: 'Copilot', href: '/docs/install/per-agent-guides/copilot/' },
      { label: 'Windsurf', href: '/docs/install/per-agent-guides/windsurf/' },
    ],
  },
  {
    label: 'DOCS',
    links: [
      { label: 'Overview', href: '/docs' },
      { label: 'CLI', href: '/docs/install/cli-reference/' },
      { label: 'API', href: '/docs/reference/api/' },
      { label: 'Methodology', href: '/methodology' },
      { label: 'Detection rules', href: '/methodology#rules' },
    ],
  },
  {
    label: 'PROJECT',
    links: [
      { label: 'About', href: '/about' },
      { label: 'Join Slack Community', href: '/slack' },
      { label: 'Privacy', href: '/privacy' },
      { label: 'Cookie policy', href: '/cookies' },
      { label: 'GitHub', href: 'https://github.com/OpenLatch/saferskills', external: true },
    ],
  },
]
---
<footer class="footer">
  <div class="container">
    <div class="ft-top">
      <div class="ft-brand">
        <span class="word">
          <img
            class="mk"
            src="/logos/saferskills-logo-animated.svg"
            alt=""
            aria-hidden="true"
          />
          SaferSkills
        </span>
        <p>
          Independent, open-source security scanning for AI agents and the capabilities they run.
        </p>
        <p class="ft-meta">
          An <a href="https://openlatch.ai" rel="noopener">OpenLatch</a> project
        </p>
        <ThemeToggle client:idle />
      </div>
      {cols.map((col) => (
        <div class="ft-col">
          <h6>{col.label}</h6>
          <ul>
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  rel={link.external ? 'noopener' : undefined}
                  target={link.external ? '_blank' : undefined}
                >{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</footer>
