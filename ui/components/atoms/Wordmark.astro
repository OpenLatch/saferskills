---
/**
 * SaferSkills wordmark.
 *
 * Onest 600 monochrome per Wordmark Spec lock 2026-05-27 — slate-900 on light,
 * white on dark. 4 sizes (sm / md / lg / hero). Logo (S-monogram) pairs left.
 *
 * D-FE-05 / D-FE-36: brand stays monochrome — no two-tone wordmark
 * surfaces beyond the standalone logo asset.
 */
import Logo from './Logo.astro'

interface Props {
  size?: 'sm' | 'md' | 'lg' | 'hero'
  href?: string | null
  ariaLabel?: string
}
const { size = 'md', href = '/', ariaLabel = 'SaferSkills home' } = Astro.props

// Logo height tracks the text cap-height (~0.71 × font-size for Onest 600)
// with a small optical buffer so the S-monogram reads as a visual peer of the
// wordmark rather than an oversized prefix. Ratio ≈ 0.8 × text size.
const sizing = {
  sm:   { logo: 14, text: 16, gap: 8 },
  md:   { logo: 20, text: 24, gap: 10 },
  lg:   { logo: 30, text: 36, gap: 12 },
  hero: { logo: 42, text: 52, gap: 14 },
}[size]
const inlineVars = `--wm-logo:${sizing.logo}px;--wm-text:${sizing.text}px;--wm-gap:${sizing.gap}px;`
---
{href ? (
  <a href={href} class="wordmark" style={inlineVars} aria-label={ariaLabel}>
    <Logo size={sizing.logo} />
    <span class="wordmark-text">SaferSkills</span>
  </a>
) : (
  <span class="wordmark" style={inlineVars}>
    <Logo size={sizing.logo} />
    <span class="wordmark-text">SaferSkills</span>
  </span>
)}

<style>
  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: var(--wm-gap);
    text-decoration: none;
    color: var(--fg-1);
    line-height: 1;
  }
  .wordmark-text {
    font-family: var(--font-wordmark);
    font-weight: 600;
    font-size: var(--wm-text);
    letter-spacing: -0.02em;
    line-height: 1;
    color: inherit;
  }
  a.wordmark { transition: opacity var(--dur-xs) var(--ease-std); }
  a.wordmark:hover { opacity: 0.85; }
</style>
