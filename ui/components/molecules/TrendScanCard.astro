---
/**
 * Trending card in the feeds mosaic — `.scan-card.trend`.
 *
 * Static markup. Visual contract owned by
 * `webapp/src/styles/page-home.css::.feeds-band .scan-card.trend`. Renders
 * a leading rank-pill (#1/#2/#3) over the title, then a `.trend-stats` row
 * with weekly installs + delta, then a `.score-line` with the sparkline
 * blocks and the band-tier mono label.
 */
type Tier = 'green' | 'yellow' | 'orange' | 'red'

interface Props {
  rank: number
  slug: string
  name: string
  score: number
  tier: Tier
  installsLast7d: number
  installsDelta: number
  /** Block-character sparkline (▁▂▃▄▅▆▇█); 7 chars look best. */
  sparkBlocks?: string
}

const {
  rank,
  slug,
  name,
  score,
  tier,
  installsLast7d,
  installsDelta,
  sparkBlocks = '▁▂▂▃▅▇█',
} = Astro.props

const tierToBand: Record<Tier, string> = {
  green: 'Green',
  yellow: 'Yellow',
  orange: 'Orange',
  red: 'Red',
}
const tierToSw: Record<Tier, string> = {
  green: 'green',
  yellow: 'yellow',
  orange: 'orange',
  red: 'orange',
}
const tierLabel = tierToBand[tier]
const iconMono = tier === 'green' ? 'G' : tier === 'yellow' ? 'Y' : 'O'
const iconMod = tier === 'yellow' ? 'yellow' : tier === 'green' ? '' : 'orange'
const formatInstalls = (n: number): string => n >= 1000 ? `${(n / 1000).toFixed(1).replace(/\.0$/, '')}k` : String(n)
const deltaPrefix = installsDelta >= 0 ? '+' : ''
---
<a class="scan-card trend" href={`/items/${slug}`} aria-label={`#${rank} ${name} — score ${score}`}>
  <div class="row">
    <div class="body">
      <div class="rank-pill">TRENDING · <b>#{rank}</b></div>
      <div class="name">{name}</div>
      <div class="meta">{score}/100 · {tierLabel} band</div>
    </div>
    <span class={`icon-mark ${iconMod}`.trim()}>{iconMono}</span>
  </div>
  <div class="trend-stats">
    <div><span class="num">{formatInstalls(installsLast7d)}</span> installs / wk</div>
    <div class="delta">{deltaPrefix}{installsDelta}% ↑</div>
  </div>
  <div class="score-line">
    <div class="trend-spark">{sparkBlocks}</div>
    <span class="band" style="margin-left: auto;">
      <span class={`sw ${tierToSw[tier]}`}></span>7-day
    </span>
  </div>
</a>
