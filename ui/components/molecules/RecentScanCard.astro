---
/**
 * Card in the homepage's feeds mosaic — `.scan-card.recent` per Phase A2.
 *
 * Rendered as static HTML; no React hydration. Layout owned by the homepage
 * mosaic in `webapp/src/styles/page-home.css::.feeds-band .scan-card.recent`.
 * Drops the dotstrip + band-pill from the W1/A1 design — the mockup mosaic
 * keeps each cell visually quieter so the 3 × 3 grid breathes.
 */
type Kind = 'skill' | 'mcp_server' | 'hook' | 'plugin' | 'rules'
type Tier = 'green' | 'yellow' | 'orange' | 'red'

interface Props {
  slug: string
  name: string
  author: string
  kind: Kind
  score: number
  tier: Tier
  scannedAtRelative: string
  findingCount?: number
  /** Stable key (e.g. "recent-0") so the homepage live island can re-render
   * this cell from fresh data without a full reload. */
  liveKey?: string
}

const {
  slug,
  name,
  author,
  kind,
  score,
  tier,
  scannedAtRelative,
  findingCount,
  liveKey,
} = Astro.props

const tierToIconClass: Record<Tier, string> = {
  green: '',          // default is green
  yellow: 'yellow',
  orange: 'orange',
  red: 'orange',      // mockup uses 3 shades on the icon mark; map red → orange swatch
}
const tierToBand: Record<Tier, string> = {
  green: 'Green',
  yellow: 'Yellow',
  orange: 'Orange',
  red: 'Red',
}
const tierToSw: Record<Tier, string> = {
  green: 'green',
  yellow: 'yellow',
  orange: 'orange',
  red: 'orange',
}
const iconMod = tierToIconClass[tier]
const monoLetter = tier === 'red' || tier === 'orange'
  ? 'O'
  : tier === 'yellow' ? 'Y' : 'G'
---
<a class="scan-card recent" href={`/items/${slug}`} aria-label={`${name} — score ${score} of 100`} data-live-card={liveKey}>
  <div class="row">
    <div class="body">
      <div class="rank-pill">SCAN · {scannedAtRelative}</div>
      <div class="name">{name}</div>
      <div class="meta">
        {author} · {kind.replace('_', ' ')}
        {typeof findingCount === 'number' && findingCount > 0 ? (
          <span class="warn"> · {findingCount} finding{findingCount === 1 ? '' : 's'}</span>
        ) : null}
      </div>
    </div>
    <span class={`icon-mark ${iconMod}`.trim()}>{monoLetter}</span>
  </div>
  <div class="score-line">
    <span class="score-num">{score}<span class="slash">/100</span></span>
    <span class="band"><span class={`sw ${tierToSw[tier]}`}></span>{tierToBand[tier]}</span>
  </div>
</a>
