# SaferSkills webapp — environment variables.
# Vite-style PUBLIC_ prefix exposes the value at runtime in the bundle —
# never put a real secret behind a PUBLIC_ key.

# Backend origin the in-app `/api/*` reverse proxy forwards to. Server-only and
# RUNTIME (intentionally NOT PUBLIC_*): it is read by the webapp Node server, not
# inlined into the client bundle, so one build serves every environment. The
# browser always calls same-origin `/api/*`; only the server needs this. Set per
# environment (webapp/fly.*.toml, docker-compose). See env.ts + the proxy route.
API_ORIGIN=http://localhost:8000

# Shared secret the `/api/*` proxy sends as `X-Proxy-Secret` so the API trusts
# the forwarded visitor IP for per-IP rate limiting. Server-only RUNTIME secret
# (NOT PUBLIC_*), must equal the API's SAFERSKILLS_PROXY_SHARED_SECRET. Empty →
# no header (the API then keys rate limits on the raw peer). See the proxy route.
SAFERSKILLS_PROXY_SHARED_SECRET=

# Server-only RUNTIME Sentry DSN for the Astro SSR + `/api/*` proxy error path
# (read by webapp/src/middleware.ts via @sentry/node, NOT PUBLIC_*, never inlined
# into the client bundle). Empty → server-side Sentry is a no-op. Separate from
# the browser PUBLIC_SENTRY_DSN below (same project, distinct DSN is fine).
SENTRY_DSN=

# The client API base is derived at runtime (browser → window.location.origin),
# so PUBLIC_API_URL is no longer required for client fetches. Kept only as the
# local-dev/test fallback default consumed by env.ts.
PUBLIC_API_URL=http://localhost:8000
# PUBLIC_* below are BUILD-TIME: inlined into the Astro bundle at `pnpm build`
# (the deploy passes them as Docker --build-args). They ship in the client bundle
# by design (PostHog project key + Sentry browser DSN are public).
PUBLIC_POSTHOG_KEY=
PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
PUBLIC_SENTRY_DSN=
# Cloudflare Turnstile site key for the scan-submit human gate. Empty → the
# verification modal is skipped and scans submit directly (preserves dev UX). In
# non-prod use Cloudflare's always-pass test site key: 1x00000000000000000000AA
PUBLIC_TURNSTILE_SITE_KEY=
