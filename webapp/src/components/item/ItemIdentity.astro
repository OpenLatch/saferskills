---
import { env } from '@/env'
import type { CatalogItemDetail } from '@/lib/api/items'
import type { ScanReportDetail } from '@/lib/api/scans'

interface Props {
  item: CatalogItemDetail
  scan: ScanReportDetail | null
}

const { item, scan } = Astro.props

const KIND_LABEL: Record<string, string> = {
  skill: 'Skill',
  mcp_server: 'MCP server',
  hook: 'Hook',
  plugin: 'Plugin',
  rules: 'Rules',
}

const jsonUrl = `${env.PUBLIC_API_URL}/api/v1/items/${item.slug}`
const githubLabel = item.github_url ? item.github_url.replace(/^https?:\/\//, '') : null
const scannedAt = scan ? new Date(scan.scanned_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : null
---

<section class="item-identity">
  <div class="container">
    <div class="item-identity-main">
      <h2 class="item-name">
        {item.display_name}
        <span class="meta">by {item.github_org} · {KIND_LABEL[item.kind] ?? item.kind}</span>
      </h2>
      {githubLabel && (
        <a class="item-link" href={item.github_url} rel="noopener">{githubLabel}</a>
      )}
      {scannedAt && (
        <div class="item-meta-row">
          last scan {scannedAt} ·{' '}
          <a class="re-scan" href={`/scan?prefill=${encodeURIComponent(item.github_url ?? '')}`}>re-scan</a>
        </div>
      )}
    </div>
    <div class="item-actions">
      <button type="button" class="btn paper sm" data-share aria-label="Copy a link to this report">↗ Share</button>
      <a class="btn paper sm" href={jsonUrl} target="_blank" rel="noopener" aria-label="Open the raw JSON for this item">↓ JSON</a>
    </div>
  </div>
</section>

<script is:inline>
  document.querySelector('[data-share]')?.addEventListener('click', async () => {
    try {
      if (navigator.share) {
        await navigator.share({ url: window.location.href, title: document.title })
      } else {
        await navigator.clipboard.writeText(window.location.href)
      }
    } catch {
      /* user cancelled — no-op */
    }
  })
</script>
