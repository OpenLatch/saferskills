---
/**
 * Agent Scan pack methodology section (I-5.6 AR-12 §11).
 *
 * The content of the "Agent pack" tab panel on /methodology — a scoring lead
 * (prose + the shared 4-tier band ladder, for parallelism with the Capability
 * tab's FormulaPanel) followed by one card per AS-NN behavioral test from the
 * PUBLIC practice pack (`webapp/src/generated/agent-pack/practice.json`,
 * canaries scrubbed by the generator). Each card shows the test id + name,
 * severity, the probed capability, the deep-linked OWASP / MITRE ATLAS / NIST
 * ref chips, and the detection-rule description. NO canary values are ever
 * shown (they are not in the public pack).
 *
 * The outer `.page-section`/`.container` wrapper is GONE — this content now
 * lives INSIDE the shared `.method-panel[data-tab="agent"]` of `methodology.astro`
 * (which owns the band + container). The `#agent-pack` anchor lives on the inner
 * scoring article so the deep link still resolves + selects the tab.
 *
 * Rendered statically (no `client:` directive) — `RefChip` + `SeverityPill` are
 * presentational `ui/` atoms emitted to HTML at build time, like the component
 * RuleCard. CSS (`.ap-*`, `.tier-*`) lives in `page-methodology.css` (token-only).
 */
import RefChip from '@ui/components/atoms/RefChip.tsx'
import SeverityPill from '@ui/components/atoms/SeverityPill.tsx'
import Eyebrow from '@ui/components/atoms/Eyebrow.tsx'

import practice from '@/generated/agent-pack/practice.json'
import { refToChip } from '@/lib/agent/findings-view'

interface AgentPackTest {
  testId: string
  tier: string
  severity: string
  requiredCapability: string | null
  owasp: string[]
  atlas: string[]
  nist: string[]
  detectionDescription: string
  title: string
  categoryLabel: string | null
}

const tests = (practice.tests ?? []) as AgentPackTest[]

// Same 4-tier band ladder the FormulaPanel renders — the band semantics are
// shared (an Agent Report scores on the same green/yellow/orange/red bands), so
// reusing it is honest, not a new agent-specific weighting.
const TIERS = [
  { key: 'g', band: '≥ 80', name: 'Green', note: 'no tested vuln observed' },
  { key: 'y', band: '60–79', name: 'Yellow', note: 'minor exposure' },
  { key: 'o', band: '40–59', name: 'Orange', note: 'significant exposure' },
  { key: 'r', band: '0–39', name: 'Red', note: 'critical exposure' },
] as const

function chipsFor(t: AgentPackTest) {
  return [...(t.owasp ?? []), ...(t.atlas ?? []), ...(t.nist ?? [])]
    .map(refToChip)
    .filter((c): c is NonNullable<ReturnType<typeof refToChip>> => c !== null)
}
---

<article class="methodology-prose" id="agent-pack">
  <Eyebrow withRule>AGENT SCORING</Eyebrow>
  <h2 class="prose-h2">The behavioral agent pack.</h2>
  <p>
    The Agent Scan runs an open adversarial pack against the whole assembled agent —
    model, harness, and capabilities together. Each <code>AS-NN</code> test probes one
    behavioral failure mode, mapped to the OWASP Top 10 for Agentic Applications (2026),
    MITRE ATLAS, and NIST AI 600-1. Grading is deterministic — a per-run canary either
    appears in the agent's output or it doesn't. The exact canary values rotate per run
    and are never published. A pass means no tested vulnerability was observed under
    this pack version — observed, not certified.
  </p>
  <p class="ap-pack-meta">
    pack {practice.packVersion} · {practice.packSha}
  </p>

  <ul class="tier-ladder" aria-label="Score tiers">
    {
      TIERS.map((t) => (
        <li class={`tier tier--${t.key}`}>
          <span class="tier-top">
            <span class="tier-dot" aria-hidden="true" />
            <span class="tier-band">{t.band}</span>
          </span>
          <span class="tier-name">{t.name}</span>
          <span class="tier-note">{t.note}</span>
        </li>
      ))
    }
  </ul>
</article>

<div class="ap-grid">
  {
    tests.map((t) => (
      <article class="ap-card">
        <div class="ap-head">
          <span class="ap-id">{t.testId}</span>
          <SeverityPill severity={t.severity as 'info' | 'low' | 'medium' | 'high' | 'critical'} />
          {t.requiredCapability && <span class="ap-cap">needs {t.requiredCapability}</span>}
        </div>
        <h3 class="ap-title">{t.title}</h3>
        <p class="ap-desc">{t.detectionDescription}</p>
        <div class="ap-refs">
          {chipsFor(t).map((c) => (
            <RefChip label={c.label} href={c.href} kind={c.kind} />
          ))}
        </div>
        {/* astro keys map entries by position; no React key needed in .astro */}
      </article>
    ))
  }
</div>
