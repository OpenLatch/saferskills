---
/**
 * RuleCard — renders one rubric rule on the public /methodology page.
 *
 * Props come from `webapp/src/generated/methodology/index.mdx`, which is
 * auto-generated by `scripts/generate-methodology.cjs` from `rubric/`. The
 * upstream rule file is permalinked at the rubricSha for vendor-reproducibility.
 *
 * Visual language follows ui/styles/tokens.css: 0px radius, 1px hairline
 * borders, cobalt primary, 4-band score colors. No bespoke styling.
 */

interface Props {
  ruleId: string
  severity: 'info' | 'low' | 'medium' | 'high' | 'critical'
  subScore: 'security' | 'supply_chain' | 'maintenance' | 'transparency' | 'community'
  status: 'shadow' | 'active' | 'deprecated'
  weight: number
  appliesTo: ReadonlyArray<'skill' | 'mcp' | 'rules' | 'hooks' | 'plugin'>
  triggerSummary: string
  limitations: ReadonlyArray<string>
  sourcePath: string
  rubricSha: string
}

const props = Astro.props as Props
// rubricSha is a content-addressable git TREE hash of rubric/ (stable across
// local + CI; survives PR merge-commit SHA differences). It's the identity of
// the rubric version; the GitHub /blob/<ref>/<path> URL however needs a
// commit-ish ref, so the source link points at the main branch.
const sourceHref = `https://github.com/OpenLatch/saferskills/blob/main/${props.sourcePath}`

const severityClass = `sev-${props.severity}`
const statusClass = `status-${props.status}`
---

<article class={`rule-card ${severityClass} ${statusClass}`}>
  <header class="rule-card__head">
    <code class="rule-card__id">{props.ruleId}</code>
    <span class={`rule-card__sev rule-card__sev--${props.severity}`}>{props.severity}</span>
    <span class={`rule-card__status rule-card__status--${props.status}`}>{props.status}</span>
    {props.status === 'shadow' ? (
      <span class="rule-card__weight">weight 0 (shadow)</span>
    ) : (
      <span class="rule-card__weight">weight {props.weight}</span>
    )}
  </header>

  <p class="rule-card__trigger">{props.triggerSummary}</p>

  <details class="rule-card__limitations">
    <summary>Limitations ({props.limitations.length})</summary>
    <ul>
      {props.limitations.map((lim) => <li>{lim}</li>)}
    </ul>
  </details>

  <footer class="rule-card__foot">
    <span class="rule-card__applies">
      Applies to: {props.appliesTo.join(', ')}
    </span>
    <a href={sourceHref} rel="noopener" class="rule-card__source">
      Source ({props.sourcePath.split('/').pop()})
    </a>
  </footer>
</article>

<style>
  .rule-card {
    border: var(--border-width) solid rgb(var(--border));
    padding: var(--space-4);
    margin-block: var(--space-3);
    background: rgb(var(--background));
    font-size: var(--type-sm);
    line-height: 1.5;
  }
  .rule-card__head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
  }
  .rule-card__id {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: var(--type-sm);
    color: rgb(var(--foreground));
  }
  .rule-card__sev,
  .rule-card__status {
    font-size: var(--type-2xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 2px 6px;
    border: var(--border-width) solid rgb(var(--border));
  }
  .rule-card__sev--critical { background: rgb(var(--score-red)); color: white; border-color: rgb(var(--score-red)); }
  .rule-card__sev--high     { background: rgb(var(--score-orange)); color: white; border-color: rgb(var(--score-orange)); }
  .rule-card__sev--medium   { background: rgb(var(--score-yellow)); color: rgb(var(--foreground)); border-color: rgb(var(--score-yellow)); }
  .rule-card__sev--low      { background: rgb(var(--muted)); color: rgb(var(--muted-fg)); }
  .rule-card__sev--info     { background: rgb(var(--muted)); color: rgb(var(--muted-fg)); }
  .rule-card__status--active { color: rgb(var(--score-green)); border-color: rgb(var(--score-green)); }
  .rule-card__status--shadow { color: rgb(var(--muted-fg)); }
  .rule-card__status--deprecated { color: rgb(var(--muted-fg)); text-decoration: line-through; }
  .rule-card__weight {
    font-size: var(--type-2xs);
    color: rgb(var(--muted-fg));
    margin-left: auto;
  }
  .rule-card__trigger {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: var(--type-xs);
    color: rgb(var(--muted-fg));
    margin-block: var(--space-2);
    word-break: break-word;
  }
  .rule-card__limitations {
    margin-block: var(--space-2);
  }
  .rule-card__limitations summary {
    cursor: pointer;
    font-size: var(--type-xs);
    color: rgb(var(--muted-fg));
  }
  .rule-card__limitations ul {
    margin: var(--space-2) 0 0 var(--space-4);
    color: rgb(var(--muted-fg));
    font-size: var(--type-xs);
  }
  .rule-card__limitations li { margin-block: var(--space-1); }
  .rule-card__foot {
    display: flex;
    justify-content: space-between;
    gap: var(--space-3);
    margin-top: var(--space-3);
    padding-top: var(--space-2);
    border-top: var(--border-width) dashed rgb(var(--border));
    font-size: var(--type-xs);
    color: rgb(var(--muted-fg));
  }
  .rule-card__source {
    color: rgb(var(--primary));
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
