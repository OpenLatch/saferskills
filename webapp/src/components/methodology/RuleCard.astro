---
/**
 * RuleCard — one rubric rule on the public /methodology page.
 *
 * Props arrive from `webapp/src/generated/methodology/index.mdx`, which is
 * auto-generated by `scripts/generate-methodology.cjs` from `rubric/`. The
 * upstream rule file is permalinked at the rubricSha for vendor reproducibility.
 *
 * The card is self-explanatory: a plain-English `title` headline, a neutralized
 * `description`, an OWASP/MITRE/CWE framework badge row, the `SeverityPill` (shared
 * with the scan-report finding card), and the raw regex collapsed behind a
 * "Detection logic" fold. `rule_id` is demoted to a mono meta line.
 *
 * Visual language locked to ui/styles/tokens.css: 0 radius, 1px hairlines,
 * brand-teal primary, 5-tier severity chips. Carries an anchor
 * id=<rule_id.toLowerCase()> so the homepage attack-grid + methodology TOC can
 * deep-link to specific rules.
 */
import SeverityPill from '@ui/components/atoms/SeverityPill.tsx'
import FrameworkBadges, { type FrameworkRef } from '@ui/components/atoms/FrameworkBadges.tsx'
import { renderInlineCode } from '@/lib/rule-prose'

interface Props {
  ruleId: string
  title: string
  categoryLabel: string
  description: string
  severity: 'info' | 'low' | 'medium' | 'high' | 'critical'
  subScore: 'security' | 'supply_chain' | 'maintenance' | 'transparency' | 'community'
  status: 'shadow' | 'active' | 'deprecated'
  weight: number
  appliesTo: ReadonlyArray<'skill' | 'mcp' | 'rules' | 'hooks' | 'plugin'>
  frameworks: ReadonlyArray<FrameworkRef>
  triggerSummary: string
  limitations: ReadonlyArray<string>
  searchIndex: string
  sourcePath: string
  rubricSha: string
}

const props = Astro.props as Props

const sourceHref = `https://github.com/OpenLatch/saferskills/blob/main/${props.sourcePath}`
const anchorId = props.ruleId.toLowerCase()
const fileName = props.sourcePath.split('/').pop() ?? props.sourcePath
const isShadow = props.status === 'shadow'
---

<article
  id={anchorId}
  class={`rule-card sev-${props.severity} status-${props.status}`}
  data-category={props.subScore}
  data-severity={props.severity}
  data-status={props.status}
  data-applies={props.appliesTo.join(' ')}
  data-search={props.searchIndex}
>

  <header class="rc-head">
    <div class="rc-head-main">
      <h3 class="rc-name">{props.title}</h3>
      <div class="rc-meta">
        <code class="rc-id">{props.ruleId}</code>
        <span class="rc-dot" aria-hidden="true">·</span>
        <span class="rc-cat">{props.categoryLabel}</span>
      </div>
    </div>
    <div class="rc-head-side">
      <SeverityPill severity={props.severity} />
      <span class={`rc-status rc-status--${props.status}`}>{props.status}</span>
      <span class="rc-weight" aria-label={`Weight ${isShadow ? 0 : props.weight}`}>
        <span class="rc-weight-num">{isShadow ? 0 : props.weight}</span>
        <span class="rc-weight-lbl">weight</span>
      </span>
    </div>
  </header>

  <p class="rc-desc" set:html={renderInlineCode(props.description)} />

  <details class="rc-detection">
    <summary>Detection logic</summary>
    <p class="rc-trigger">{props.triggerSummary}</p>
  </details>

  {props.limitations.length > 0 && (
    <details class="rc-limitations">
      <summary>Limitations ({props.limitations.length})</summary>
      <ul>
        {props.limitations.map((lim) => <li>{lim}</li>)}
      </ul>
    </details>
  )}

  <footer class="rc-foot">
    {props.frameworks.length > 0 && (
      <div class="rc-frameworks">
        <span class="rc-frameworks-lbl">maps to</span>
        <FrameworkBadges frameworks={props.frameworks} />
      </div>
    )}
    <div class="rc-foot-row">
      <div class="rc-applies">
        <span class="rc-applies-lbl">applies to</span>
        {props.appliesTo.map((kind) => (
          <span class="rc-kind">{kind}</span>
        ))}
      </div>
      <a class="rc-source" href={sourceHref} rel="noopener" target="_blank">
        <span class="rc-source-lbl">source</span>
        <span class="rc-source-file">{fileName}</span>
        <span aria-hidden="true">↗</span>
      </a>
    </div>
  </footer>
</article>

<style>
  .rule-card {
    border: 1px solid var(--color-ink);
    background: var(--color-paper);
    padding: 20px 22px;
    margin-block: 14px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    scroll-margin-top: 96px;
    transition: border-color var(--dur-xs) var(--ease-std);
  }
  .rule-card:target {
    border-color: var(--brand-primary);
    box-shadow: var(--shadow-stamp);
  }
  .rule-card.status-deprecated {
    opacity: 0.65;
  }

  .rc-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    flex-wrap: wrap;
  }
  .rc-head-main {
    min-width: 0;
    flex: 1 1 320px;
  }
  .rc-name {
    font-family: var(--font-sans);
    font-size: 16px;
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    margin: 0;
    text-wrap: pretty;
  }
  html.dark .rc-name {
    color: var(--fg-1);
  }
  .rc-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 7px;
    flex-wrap: wrap;
  }
  .rc-id {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--fg-2);
    line-height: 1.3;
    word-break: break-all;
  }
  .rc-dot {
    color: var(--fg-3);
  }
  .rc-cat {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-3);
  }
  .rc-head-side {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  /* Keep the SeverityPill vertically centered with the status chip + weight (the
     ported `.sev` defaults to align-self:flex-start for the FindingDetail summary). */
  .rc-head-side :global(.sev) {
    align-self: center;
  }
  /* Status chip — a simple squared filled tag, deliberately a different shape from
     the bordered + swatched SeverityPill (homogeneous, no hex-cap mask). 3 states. */
  .rc-status {
    display: inline-flex;
    align-items: center;
    /* Match the SeverityPill (`.sev`) box exactly — same vertical padding + a 1px
       (transparent) border + 10px font — so both chips are the same height. */
    padding: 5px 11px;
    border: 1px solid transparent;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    border-radius: var(--radius-xs);
  }
  .rc-status--active     { background: rgba(13, 148, 136, 0.16); color: var(--brand-primary); }
  .rc-status--shadow     { background: var(--color-paper-deep); color: var(--fg-3); }
  .rc-status--deprecated { background: rgba(239, 68, 68, 0.14); color: var(--score-red); text-decoration: line-through; }

  /* Weight column — small loud-font number + mono label */
  .rc-weight {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-end;
    line-height: 1;
    min-width: 48px;
  }
  .rc-weight-num {
    font-family: var(--font-loud);
    font-stretch: 125%;
    font-weight: 800;
    font-size: 26px;
    letter-spacing: -0.04em;
    color: var(--fg-1);
  }
  .rc-weight-lbl {
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-3);
    margin-top: 4px;
  }

  /* Plain-English description */
  .rc-desc {
    font-family: var(--font-sans);
    font-size: 14px;
    line-height: 1.6;
    color: var(--fg-2);
    margin: 0;
    text-wrap: pretty;
  }
  .rc-desc :global(code) {
    font-family: var(--font-mono);
    font-size: 0.88em;
    background: var(--color-paper-deep);
    padding: 1px 5px;
    border-radius: var(--radius-xs);
    color: var(--fg-1);
    word-break: break-word;
  }
  html.dark .rc-desc :global(code) {
    background: var(--bg-surface-mute);
  }

  /* Detection-logic fold (the raw trigger) */
  .rc-detection,
  .rc-limitations {
    margin: 0;
    font-size: 13px;
  }
  .rc-detection summary,
  .rc-limitations summary {
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-3);
    padding: 6px 0;
    list-style: none;
  }
  .rc-detection summary::before,
  .rc-limitations summary::before {
    content: '▸ ';
    color: var(--brand-primary);
    display: inline-block;
    transition: transform var(--dur-xs) var(--ease-std);
  }
  .rc-detection[open] summary::before,
  .rc-limitations[open] summary::before {
    content: '▾ ';
  }
  .rc-detection summary:hover,
  .rc-limitations summary:hover {
    color: var(--fg-1);
  }

  /* Trigger summary — mono, wrapped, slate-deep paper */
  .rc-trigger {
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 1.55;
    color: var(--fg-2);
    background: var(--color-paper-deep);
    border-left: 2px solid var(--brand-primary);
    padding: 10px 14px;
    margin: 8px 0 0;
    word-break: break-word;
  }

  /* Limitations list */
  .rc-limitations ul {
    list-style: none;
    margin: 8px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .rc-limitations li {
    font-family: var(--font-sans);
    font-size: 13px;
    font-style: italic;
    line-height: 1.5;
    color: var(--fg-2);
    padding-left: 16px;
    position: relative;
  }
  .rc-limitations li::before {
    content: '–';
    position: absolute;
    left: 0;
    color: var(--fg-3);
    font-style: normal;
  }

  /* Footer — frameworks row + applies-to + source */
  .rc-foot {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-top: 12px;
    border-top: 1px dashed var(--color-line);
  }
  .rc-frameworks {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .rc-frameworks-lbl {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fg-3);
  }
  .rc-foot-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .rc-applies {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .rc-applies-lbl {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fg-3);
  }
  .rc-kind {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    background: var(--color-paper-deep);
    color: var(--fg-2);
    border: 1px solid var(--color-line);
    padding: 3px 9px;
    text-transform: lowercase;
  }
  .rc-source {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--brand-primary);
    text-decoration: none;
    transition: color var(--dur-xs);
  }
  .rc-source-lbl {
    color: var(--fg-3);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-size: 10px;
  }
  .rc-source-file {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .rc-source:hover .rc-source-file {
    color: var(--brand-primary-dark);
  }

  /* Dark mode */
  html.dark .rule-card {
    background: var(--bg-page-alt);
    border-color: var(--color-line);
  }
  html.dark .rule-card:target {
    border-color: var(--brand-primary);
  }
  html.dark .rc-trigger,
  html.dark .rc-kind {
    background: var(--bg-surface-mute);
  }
  html.dark .rc-status--shadow { background: var(--bg-surface-mute); color: var(--fg-2); }
  html.dark .rc-status--active { background: rgba(13, 148, 136, 0.22); color: var(--brand-primary); }

  /* Mobile */
  @media (max-width: 640px) {
    .rule-card {
      padding: 16px 18px;
    }
    .rc-head-side {
      width: 100%;
      justify-content: flex-start;
    }
    .rc-weight {
      align-items: flex-start;
    }
    .rc-weight-num {
      font-size: 22px;
    }
    .rc-foot-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
    }
  }
</style>
