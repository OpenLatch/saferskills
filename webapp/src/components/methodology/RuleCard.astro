---
/**
 * RuleCard — one rubric rule on the public /methodology page.
 *
 * Props arrive from `webapp/src/generated/methodology/index.mdx`, which is
 * auto-generated by `scripts/generate-methodology.cjs` from `rubric/`. The
 * upstream rule file is permalinked at the rubricSha for vendor reproducibility.
 *
 * Visual language locked to ui/styles/tokens.css: 0 radius, 1px hairlines,
 * brand-teal primary, 4-tier score colors, 5-tier severity chips. Carries an
 * anchor id=<rule_id.toLowerCase()> so the homepage attack-grid + methodology
 * TOC can deep-link to specific rules.
 */

interface Props {
  ruleId: string
  severity: 'info' | 'low' | 'medium' | 'high' | 'critical'
  subScore: 'security' | 'supply_chain' | 'maintenance' | 'transparency' | 'community'
  status: 'shadow' | 'active' | 'deprecated'
  weight: number
  appliesTo: ReadonlyArray<'skill' | 'mcp' | 'rules' | 'hooks' | 'plugin'>
  triggerSummary: string
  limitations: ReadonlyArray<string>
  sourcePath: string
  rubricSha: string
}

const props = Astro.props as Props

const sourceHref = `https://github.com/OpenLatch/saferskills/blob/main/${props.sourcePath}`
const anchorId = props.ruleId.toLowerCase()
const fileName = props.sourcePath.split('/').pop() ?? props.sourcePath
const isShadow = props.status === 'shadow'
---

<article
  id={anchorId}
  class={`rule-card sev-${props.severity} status-${props.status}`}
  data-category={props.subScore}
  data-severity={props.severity}
  data-status={props.status}
  data-applies={props.appliesTo.join(' ')}
  data-search={`${props.ruleId} ${props.triggerSummary}`.toLowerCase()}
>

  <header class="rc-head">
    <code class="rc-id">{props.ruleId}</code>
    <div class="rc-chips">
      <span class={`rc-chip rc-sev rc-sev--${props.severity}`}>{props.severity}</span>
      <span class={`rc-chip rc-status rc-status--${props.status}`}>{props.status}</span>
    </div>
    <span class="rc-weight" aria-label={`Weight ${isShadow ? 0 : props.weight}`}>
      <span class="rc-weight-num">{isShadow ? 0 : props.weight}</span>
      <span class="rc-weight-lbl">weight</span>
    </span>
  </header>

  <p class="rc-trigger">{props.triggerSummary}</p>

  {props.limitations.length > 0 && (
    <details class="rc-limitations">
      <summary>Limitations ({props.limitations.length})</summary>
      <ul>
        {props.limitations.map((lim) => <li>{lim}</li>)}
      </ul>
    </details>
  )}

  <footer class="rc-foot">
    <div class="rc-applies">
      <span class="rc-applies-lbl">applies to</span>
      {props.appliesTo.map((kind) => (
        <span class="rc-kind">{kind}</span>
      ))}
    </div>
    <a class="rc-source" href={sourceHref} rel="noopener" target="_blank">
      <span class="rc-source-lbl">source</span>
      <span class="rc-source-file">{fileName}</span>
      <span aria-hidden="true">↗</span>
    </a>
  </footer>
</article>

<style>
  .rule-card {
    border: 1px solid var(--color-ink);
    background: var(--color-paper);
    padding: 20px 22px;
    margin-block: 14px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    scroll-margin-top: 96px;
    transition: border-color var(--dur-xs) var(--ease-std);
  }
  .rule-card:target {
    border-color: var(--brand-primary);
    box-shadow: var(--shadow-stamp);
  }
  .rule-card.status-deprecated {
    opacity: 0.65;
  }

  .rc-head {
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
  }
  .rc-id {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--fg-1);
    line-height: 1.3;
    word-break: break-all;
  }
  .rc-chips {
    display: inline-flex;
    gap: 8px;
    align-items: center;
  }
  .rc-chip {
    --btn-h: 24px;
    --cap-w: 10px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    height: var(--btn-h);
    padding: 0 14px;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    background: var(--color-paper-deep);
    color: var(--fg-2);
    border: 0;
    -webkit-mask:
      var(--mask-hex-cap-left) left center / var(--cap-w) var(--btn-h) no-repeat,
      var(--mask-hex-cap-right) right center / var(--cap-w) var(--btn-h) no-repeat,
      linear-gradient(#000, #000) calc(var(--cap-w) - 1px) center /
      calc(100% - var(--cap-w) * 2 + 2px) var(--btn-h) no-repeat;
    mask:
      var(--mask-hex-cap-left) left center / var(--cap-w) var(--btn-h) no-repeat,
      var(--mask-hex-cap-right) right center / var(--cap-w) var(--btn-h) no-repeat,
      linear-gradient(#000, #000) calc(var(--cap-w) - 1px) center /
      calc(100% - var(--cap-w) * 2 + 2px) var(--btn-h) no-repeat;
  }
  /* Severity chips — 5 tiers */
  .rc-sev--info     { background: var(--color-paper-deep); color: var(--fg-3); }
  .rc-sev--low      { background: rgba(245, 158, 11, 0.16); color: var(--score-yellow); }
  .rc-sev--medium   { background: rgba(234, 88, 12, 0.18); color: var(--score-orange); }
  .rc-sev--high     { background: rgba(239, 68, 68, 0.18); color: var(--score-red); }
  .rc-sev--critical { background: var(--fg-1); color: var(--color-paper); }
  /* Status chips — 3 states */
  .rc-status--active     { background: rgba(13, 148, 136, 0.16); color: var(--brand-primary); }
  .rc-status--shadow     { background: var(--color-paper-deep); color: var(--fg-3); }
  .rc-status--deprecated { background: rgba(239, 68, 68, 0.14); color: var(--score-red); text-decoration: line-through; }

  /* Weight column — small loud-font number + mono label */
  .rc-weight {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-end;
    line-height: 1;
    min-width: 56px;
  }
  .rc-weight-num {
    font-family: var(--font-loud);
    font-stretch: 125%;
    font-weight: 800;
    font-size: 28px;
    letter-spacing: -0.04em;
    color: var(--fg-1);
  }
  .rc-weight-lbl {
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-3);
    margin-top: 4px;
  }

  /* Trigger summary — mono, wrapped, slate-deep paper */
  .rc-trigger {
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 1.55;
    color: var(--fg-2);
    background: var(--color-paper-deep);
    border-left: 2px solid var(--brand-primary);
    padding: 10px 14px;
    margin: 0;
    word-break: break-word;
  }

  /* Limitations details */
  .rc-limitations {
    margin: 0;
    font-size: 13px;
  }
  .rc-limitations summary {
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-3);
    padding: 6px 0;
    list-style: none;
  }
  .rc-limitations summary::before {
    content: '▸ ';
    color: var(--brand-primary);
    display: inline-block;
    transition: transform var(--dur-xs) var(--ease-std);
  }
  .rc-limitations[open] summary::before {
    content: '▾ ';
  }
  .rc-limitations summary:hover {
    color: var(--fg-1);
  }
  .rc-limitations ul {
    list-style: none;
    margin: 8px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .rc-limitations li {
    font-family: var(--font-sans);
    font-size: 13px;
    font-style: italic;
    line-height: 1.5;
    color: var(--fg-2);
    padding-left: 16px;
    position: relative;
  }
  .rc-limitations li::before {
    content: '–';
    position: absolute;
    left: 0;
    color: var(--fg-3);
    font-style: normal;
  }

  /* Footer row — applies-to chips + source link */
  .rc-foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    padding-top: 10px;
    border-top: 1px dashed var(--color-line);
  }
  .rc-applies {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .rc-applies-lbl {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fg-3);
  }
  .rc-kind {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    background: var(--color-paper-deep);
    color: var(--fg-2);
    border: 1px solid var(--color-line);
    padding: 3px 9px;
    text-transform: lowercase;
  }
  .rc-source {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--brand-primary);
    text-decoration: none;
    transition: color var(--dur-xs);
  }
  .rc-source-lbl {
    color: var(--fg-3);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-size: 10px;
  }
  .rc-source-file {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .rc-source:hover .rc-source-file {
    color: var(--brand-primary-dark);
  }

  /* Dark mode */
  html.dark .rule-card {
    background: var(--bg-page-alt);
    border-color: var(--color-line);
  }
  html.dark .rule-card:target {
    border-color: var(--brand-primary);
  }
  html.dark .rc-trigger,
  html.dark .rc-kind,
  html.dark .rc-chip {
    background: var(--bg-surface-mute);
  }
  html.dark .rc-sev--critical { background: var(--fg-1); color: var(--bg-page); }
  html.dark .rc-status--active { background: rgba(13, 148, 136, 0.22); color: var(--brand-primary); }

  /* Mobile */
  @media (max-width: 640px) {
    .rule-card {
      padding: 16px 18px;
    }
    .rc-head {
      grid-template-columns: 1fr auto;
      gap: 10px;
    }
    .rc-id {
      grid-column: 1 / -1;
      font-size: 12px;
    }
    .rc-weight {
      align-items: flex-start;
    }
    .rc-weight-num {
      font-size: 24px;
    }
    .rc-foot {
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
    }
  }
</style>
