---
/**
 * 3×3 feeds mosaic orchestrator — Phase A2.
 *
 * Per the canonical hi-fi layout:
 *   Row 1 — Recent #1 · Recent #2 · Wire (teal)
 *   Row 2 — Title cell · Recent #3 · Trending #1
 *   Row 3 — Wire (orange) · Trending #2 · Trending #3
 *
 * Falls back to 6 placeholder cards (3 recent + 3 trending) when the API
 * returns empty arrays. Cells are static; no React hydration.
 */
import RecentScanCard from '@ui/components/molecules/RecentScanCard.astro'
import TrendScanCard from '@ui/components/molecules/TrendScanCard.astro'
import TitleCell from './TitleCell.astro'
import WireCell from './WireCell.astro'

interface ScanSummary {
  slug: string
  title?: string | null
  author?: string | null
  aggregate_score: number
  tier: 'green' | 'yellow' | 'orange' | 'red' | 'unscoped'
  scanned_at: string
  findings_count?: number
}

interface Props {
  recent?: ScanSummary[]
  trending?: ScanSummary[]
}

const { recent = [], trending = [] } = Astro.props

const PLACEHOLDER_RECENT: ScanSummary[] = [
  { slug: 'acme--github-mcp', title: 'github-mcp', author: 'acme', aggregate_score: 87, tier: 'green', scanned_at: '2m ago', findings_count: 0 },
  { slug: 'alice--slack-bot', title: 'slack-bot', author: 'alice', aggregate_score: 42, tier: 'orange', scanned_at: '5m ago', findings_count: 2 },
  { slug: 'tana--obsidian-mcp', title: 'obsidian-mcp', author: 'tana', aggregate_score: 71, tier: 'yellow', scanned_at: '8m ago', findings_count: 1 },
]
const PLACEHOLDER_TRENDING: ScanSummary[] = [
  { slug: 'linear--mcp', title: 'linear-mcp', author: 'linear', aggregate_score: 96, tier: 'green', scanned_at: '7d', findings_count: 0 },
  { slug: 'notion--mcp', title: 'notion-mcp', author: 'notion', aggregate_score: 88, tier: 'green', scanned_at: '7d', findings_count: 0 },
  { slug: 'neon--mcp', title: 'neon-mcp', author: 'neon', aggregate_score: 84, tier: 'green', scanned_at: '7d', findings_count: 0 },
]

const r = (recent.length >= 3 ? recent : PLACEHOLDER_RECENT).slice(0, 3)
const t = (trending.length >= 3 ? trending : PLACEHOLDER_TRENDING).slice(0, 3)

const tierOrUnscoped = (tier: ScanSummary['tier']): 'green' | 'yellow' | 'orange' | 'red' =>
  tier === 'unscoped' ? 'red' : tier

const TREND_STATS = [
  { installs: 1247, delta: 312, spark: '▁▂▂▃▅▇█' },
  { installs: 873, delta: 94, spark: '▁▂▃▃▄▆▇' },
  { installs: 612, delta: 58, spark: '▁▁▂▃▄▅▆' },
]
---
<div class="mosaic">
  {/* Row 1 */}
  <RecentScanCard
    slug={r[0].slug}
    name={r[0].title ?? r[0].slug}
    author={r[0].author ?? 'unknown'}
    kind="skill"
    score={r[0].aggregate_score}
    tier={tierOrUnscoped(r[0].tier)}
    scannedAtRelative={r[0].scanned_at}
    findingCount={r[0].findings_count}
  />
  <RecentScanCard
    slug={r[1].slug}
    name={r[1].title ?? r[1].slug}
    author={r[1].author ?? 'unknown'}
    kind="skill"
    score={r[1].aggregate_score}
    tier={tierOrUnscoped(r[1].tier)}
    scannedAtRelative={r[1].scanned_at}
    findingCount={r[1].findings_count}
  />
  <WireCell variant="teal" />

  {/* Row 2 */}
  <TitleCell />
  <RecentScanCard
    slug={r[2].slug}
    name={r[2].title ?? r[2].slug}
    author={r[2].author ?? 'unknown'}
    kind="skill"
    score={r[2].aggregate_score}
    tier={tierOrUnscoped(r[2].tier)}
    scannedAtRelative={r[2].scanned_at}
    findingCount={r[2].findings_count}
  />
  <TrendScanCard
    rank={1}
    slug={t[0].slug}
    name={t[0].title ?? t[0].slug}
    score={t[0].aggregate_score}
    tier={tierOrUnscoped(t[0].tier)}
    installsLast7d={TREND_STATS[0].installs}
    installsDelta={TREND_STATS[0].delta}
    sparkBlocks={TREND_STATS[0].spark}
  />

  {/* Row 3 */}
  <WireCell variant="orange" />
  <TrendScanCard
    rank={2}
    slug={t[1].slug}
    name={t[1].title ?? t[1].slug}
    score={t[1].aggregate_score}
    tier={tierOrUnscoped(t[1].tier)}
    installsLast7d={TREND_STATS[1].installs}
    installsDelta={TREND_STATS[1].delta}
    sparkBlocks={TREND_STATS[1].spark}
  />
  <TrendScanCard
    rank={3}
    slug={t[2].slug}
    name={t[2].title ?? t[2].slug}
    score={t[2].aggregate_score}
    tier={tierOrUnscoped(t[2].tier)}
    installsLast7d={TREND_STATS[2].installs}
    installsDelta={TREND_STATS[2].delta}
    sparkBlocks={TREND_STATS[2].spark}
  />
</div>
