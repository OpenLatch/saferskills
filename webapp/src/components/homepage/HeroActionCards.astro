---
import AgentScanHeroCard from '@/components/homepage/AgentScanHeroCard.tsx'
import HeroInputBar from '@/components/homepage/HeroInputBar.tsx'
import HomeScanPanel from '@/components/home/HomeScanPanel.tsx'

import type { PopularChip } from '@/data/launch-fallbacks'
import type { HomepageData } from '@/lib/homepage'
import { formatCount, formatSeconds } from '@/lib/format'

interface Props {
  /** Resolved homepage view-model (live-with-fallback) — see lib/homepage.ts. */
  data: HomepageData
}

const { data } = Astro.props

// Popular-chip score swatch class (CSS supports green/yellow/orange; red→orange).
const scClass = (tier: PopularChip['tier']): string =>
  tier === 'green' ? 'green' : tier === 'yellow' ? 'yellow' : 'orange'
---
{/* Hero 3-card grid: card 01 Find full-width on top,
    cards 02 (Scan a Running Agent — inline mint) + 03 (Audit a Capability)
    side by side below. All copy verbatim from the mockup. */}

{/* Card 01 — FIND (full-width) */}
<div class="p1-card find b-wide">
  <div class="p1-head">
    <span class="seq">01</span>
    <span class="hd-title">Search the Catalog</span>
    <span class="pulse">Indexing</span>
  </div>
  <div class="p1-body">
    {/* No blurb label — the count + registries already live in the card foot
        below, so the search input itself is the invitation. */}
    <div class="b-find-search">
      <HeroInputBar
        client:idle
        kind="find"
        initialPlaceholder="ripgrep, supabase, linear..."
        ariaLabel="Search the catalog"
        submitAriaLabel="Submit search"
        shortcutKey="k"
      />
      <div class="p1-tabs" data-live-popular>
        <span class="lbl">Popular</span>
        {data.popular.map((chip) => (
          <a class="p1-chip" href={chip.href}>
            <span class="kbd">Tab</span>
            <span class="nm">{chip.name}</span>
            <span class={`sc ${scClass(chip.tier)}`}>{chip.score}</span>
          </a>
        ))}
      </div>
    </div>
  </div>
  <div class="p1-foot">
    <a class="p1-cta" href="/capabilities">Browse capabilities <span class="p1-cta-arrow" aria-hidden="true">→</span></a>
    <span class="meta"><b data-live-stat="catalog_total">{formatCount(data.catalogTotal)}</b> indexed · <b data-live-stat="registries">{data.registriesCount}</b> registries</span>
  </div>
</div>

{/* Card 02 — SCAN A RUNNING AGENT (inline mint). The island renders
    the full .p1-card so the foot can swap after a successful mint. Hydrated
    client:visible — the cards-02/03 row straddles the fold at 1440×900, and
    visible-trigger fires immediately whenever it is on screen. */}
<AgentScanHeroCard client:visible />

{/* Card 03 — AUDIT A CAPABILITY (existing dual-mode submit logic, v3 shell) */}
<div class="p1-card audit">
  <div class="p1-head">
    <span class="seq">03</span>
    <span class="hd-title">Audit a Capability</span>
    <span class="pulse">Running</span>
  </div>
  <div class="p1-body">
    <div>
      <p class="p1-blurb">
        Drop a SKILL.md or .zip, or scan a public GitHub repo → component report in ~30s.
      </p>
    </div>
    <HomeScanPanel client:visible />
  </div>
  <div class="p1-foot">
    <a class="p1-cta" href="/scan">Scan a skill <span class="p1-cta-arrow" aria-hidden="true">→</span></a>
    <span class="meta">avg <b data-live-stat="avg">{formatSeconds(data.avgLatencyMs)}</b> · free</span>
  </div>
</div>
