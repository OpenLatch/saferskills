---
// "Share this result" band — rendered on EVERY completed report (rich upload,
// multi-capability repo, multi-file upload). Public runs get the RidgeFlow
// transition + dark blueprint band + README badge terminal; unlisted runs get
// the light "badge locked until promote" variant (no ridge). The badge links to
// /items/<slug> when a single capability slug is given, else to /scans/<scanId>
// (the run report) — so a multi-capability repo badge resolves to its run.
import EmbedBadgeBox from '@ui/components/molecules/EmbedBadgeBox.tsx'
import RidgeFlow from '@ui/components/atoms/RidgeFlow.tsx'
import type { ScoredTier } from '@/lib/tier'

interface Props {
  unlisted: boolean
  scanId: string
  score: number
  tier: ScoredTier | null
  /** Capability slug → badge links to /items/<slug>; omit → /scans/<scanId>. */
  slug?: string
  /** Sub-headline copy under the H3 (differs upload vs repo). */
  sub: string
  /** Foot descriptive sentence (differs upload vs repo). */
  foot: string
  scanIdShort: string
}

const { unlisted, scanId, score, tier, slug, sub, foot, scanIdShort } = Astro.props
---

{unlisted ? (
  <section class="badge-band" data-screen-label="Private status + metadata">
    <div class="container">
      <div class="badge-wrap">
        <div class="bw-l">
          <span class="sb-eyebrow">Private link</span>
          <h3>This scan is unlisted</h3>
          <p>It is reachable only by its secret link — not indexed, not in the catalog. Promote it to public to make it shareable and badge-embeddable.</p>
        </div>
        <div class="bw-r">
          <div class="badge-locked">
            <span class="bl-lock" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="11" width="16" height="10"></rect><path d="M7.5 11 V7.5 a4.5 4.5 0 0 1 9 0 V11"></path></svg>
            </span>
            <p>A public README badge becomes available once you <b>promote this scan to public</b>. While unlisted, the result stays reachable only by its secret link.</p>
          </div>
          <div class="bw-foot">{foot} &nbsp;·&nbsp; {scanIdShort}</div>
        </div>
      </div>
    </div>
  </section>
) : (
  <>
    <RidgeFlow label="— EMBED · BADGE —" className="ridge-flow--share" />
    <section class="badge-band badge-band--share" data-screen-label="README badge embed">
      <div class="container">
        <div class="badge-wrap">
          <div class="bw-l">
            <span class="sb-eyebrow">Share this result</span>
            <h3>Embed the badge in your README</h3>
            <p>{sub}</p>
          </div>
          <div class="bw-r">
            <EmbedBadgeBox client:visible scanId={scanId} score={score} tier={tier} slug={slug} />
            <div class="bw-foot">{foot} &nbsp;·&nbsp; {scanIdShort}</div>
          </div>
        </div>
      </div>
    </section>
  </>
)}
