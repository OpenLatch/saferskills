---
// Shared COMPLETED-report body for both /scans/<run_id> (public) and
// /scans/r/<token> (unlisted). Renders one of two layouts:
//   • UPLOADS (single OR multi-file) → <UploadReport/> (mockups 3 + 4): the rich
//     score box + provenance + source/score tabs + install/pkg cards + badge.
//     A multi-file upload adds a per-file tab strip; one file = no tabs (the
//     single-file regression gate, byte-identical to the prior Astro body).
//   • REPO scans → the multi-capability cap-list layout (mockups 5 + 6): the
//     unchanged GitHub report body (`ScanReportView` + `ShareResultBand`),
//     made visibility-aware.
// `isRich` still gates the page-HEAD styling (single-file upload = rich head).
// Unlisted runs additionally get the private banner, eyebrow, manage bar, expiry
// pill, and (in <UploadReport/>) the "badge locked until promote" band. The page
// owns the anti-leakage headers + Base/nav/footer; this component is body-only.
import BandPill from '@ui/components/atoms/BandPill.tsx'
import Breadcrumb from '@ui/components/atoms/Breadcrumb.tsx'
import CopyIconButton from '@ui/components/atoms/CopyIconButton.tsx'

import ShareResultBand from '@/components/scan/ShareResultBand.tsx'
import ScanReportView from '@/components/scan/ScanReportView.tsx'
import UploadReport from '@/components/scan/UploadReport.tsx'
import UnlistedManageBar from '@/components/scan/UnlistedManageBar.tsx'
import ExpiryCountdown from '@/components/scan/ExpiryCountdown.tsx'
import { kindTag } from '@/components/catalog/constants'
import type { ScanRunReportDetail } from '@/lib/api/scans'
import { reportIdentity, scanIdShort, shortHash } from '@/lib/report-identity'
import { scoredTier, TIER_TO_STRIPE } from '@/lib/tier'

interface Props {
  run: ScanRunReportDetail
  shareUrl: string
  ruleCount: number
  /** Rendered via the capability-URL route — adds the private chrome. */
  unlisted?: boolean
  /** The capability-URL token (masked in the eyebrow, used for the .zip + manage bar). */
  token?: string
}

const { run, shareUrl, ruleCount, unlisted = false, token } = Astro.props

const { isUpload, baseTitle } = reportIdentity(run)
// `isRich` still gates the page-HEAD styling (single-file upload gets the rich
// head; the body for ALL uploads now lives in <UploadReport/>).
const isRich = isUpload && run.capability_count === 1
// Multi-file upload: the head meta reads as the "upload report" caption (N files
// + combined SHA) — the FileTabStrip drops its own caption to avoid duplication.
const isMultiUpload = isUpload && run.capability_count > 1
const cap = run.capabilities[0] ?? null

const kindLabel = cap
  ? cap.kind === 'mcp_server'
    ? 'MCP server'
    : cap.kind === 'skill'
      ? 'Agent Skill'
      : kindTag(cap.kind)
  : 'Artifact'

const shaFull = run.artifact_sha256 ?? ''
const shaShort = shortHash(shaFull)
const scanIdLabel = scanIdShort(run.id)

const fmtDate = (iso: string) =>
  new Date(iso).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })

// Consolidated facts (every value from the run DTO).
const scored = scoredTier(run.repo_tier)
const tierLetter = scored ? TIER_TO_STRIPE[scored] : ''
const tierName = scored ? scored.charAt(0).toUpperCase() + scored.slice(1) : 'Unscored'
const score = run.repo_aggregate_score
const dotsFilled = Math.max(0, Math.min(10, Math.round(score / 10)))

const caps = run.capabilities
const totalFindings = caps.reduce((n, c) => n + c.findings_summary.total, 0)
const highFindings = caps.reduce((n, c) => n + c.findings_summary.critical + c.findings_summary.high, 0)
const warnFindings = totalFindings - highFindings
const lowest = caps.length
  ? caps.reduce((a, b) => (b.aggregate_score < a.aggregate_score ? b : a))
  : null

const tallyText = Object.entries(run.kind_tally)
  .filter(([, n]) => n > 0)
  .map(([k, n]) => `${n} ${kindTag(k).toLowerCase()}${n === 1 ? '' : 's'}`)
  .join(' · ')

const latencySeconds = Math.max(0, Math.round(run.latency_ms / 1000))
const rescanHref = run.github_url ? `/scan?prefill=${encodeURIComponent(run.github_url)}` : '/scan'
const githubHost = run.github_url
  ? run.github_url.replace(/^https?:\/\//, '').replace(/\/$/, '')
  : ''

// Masked token for the private eyebrow — never the literal token.
const maskedToken = token ? `${token.slice(0, 10)}` : ''

// "Share this result" band — REPO runs only (uploads render their own per-file
// badge band inside <UploadReport/>). The repo badge links at the run report (no
// single slug).
const shareSub =
  'Add the badge to your README — it links back to this SaferSkills scan and refreshes on every re-scan.'
const shareFoot = `Reproducible by re-running rubric ${run.rubric_version.slice(0, 7)} against the same ref.`
---

{unlisted && (
  <section class="private-banner" data-screen-label="Private banner">
    <div class="container">
      <div class="pb-inner">
        <span class="pb-lock" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="11" width="16" height="10"></rect><path d="M7.5 11 V7.5 a4.5 4.5 0 0 1 9 0 V11"></path></svg>
        </span>
        <p class="pb-text"><b>Private — only people with this link can see this.</b> Not listed in the catalog or search. Anyone with the link can also delete or publish it.</p>
      </div>
    </div>
  </section>
)}

<header class={`page-head sk-head sr-head${isRich ? ' sk-head--rich' : ''}`}>
  <div class="container">
    {unlisted ? (
      <span class="ph-eyebrow">Report · Private · /scans/r/{maskedToken}…</span>
    ) : isRich ? (
      <Breadcrumb items={[{ label: 'Scan', href: '/scan' }, { label: 'Uploaded artifact' }, { label: baseTitle }]} />
    ) : (
      <Breadcrumb items={[{ label: 'Scan', href: '/scan' }, { label: isUpload ? 'Uploaded artifact' : 'Repository' }, { label: baseTitle }]} />
    )}

    <div class="sr-head-row">
      <div class="sr-head-l">
        <h1 class="ph-title">{baseTitle}<span class="script">— scan {isRich ? 'result' : 'complete'}</span></h1>
        {isRich ? (
          <p class="ph-lede">Independently scanned by SaferSkills from an uploaded artifact. Below is the consolidated security score, the full rubric breakdown, and the exact bytes we scored.</p>
        ) : (
          <p class="ph-lede">{run.capability_count} capabilit{run.capability_count === 1 ? 'y' : 'ies'} discovered · scored against {ruleCount} detectors across 5 categories.</p>
        )}
        <div class="sr-head-meta sk-head-meta">
          {isMultiUpload ? (
            <>
              <span class="up-chip">Upload report</span>
              <span class="dot">·</span>
              <span><b>{run.capability_count}</b> files scanned</span>
              <span class="dot">·</span>
              <span class="sha-cell">combined SHA-256 {shaShort}{shaFull && <CopyIconButton client:visible value={shaFull} label="Copy combined SHA-256" />}</span>
              <span class="dot">·</span>
              <span>uploaded {fmtDate(run.scanned_at)}</span>
            </>
          ) : isUpload ? (
            <>
              <span class="up-chip">Uploaded artifact</span>
              <span class="dot">·</span>
              <span>{kindLabel}</span>
              <span class="dot">·</span>
              <span class="sha-cell">SHA-256 {shaShort}{shaFull && <CopyIconButton client:visible value={shaFull} label="Copy SHA-256" />}</span>
              <span class="dot">·</span>
              <span>uploaded {fmtDate(run.scanned_at)}</span>
            </>
          ) : (
            <>
              <span class="by">scanned <b>{fmtDate(run.scanned_at)}</b></span>
              <span class="dot">·</span>
              <span>{latencySeconds}s · {ruleCount} detectors</span>
              <span class="dot">·</span>
              <a href={run.github_url} target="_blank" rel="noopener">{githubHost}</a>
            </>
          )}
          {unlisted && run.expires_at && (
            <>
              <span class="dot">·</span>
              <ExpiryCountdown client:idle expiresAt={run.expires_at} variant="pill" />
            </>
          )}
        </div>
      </div>
      <div class="sr-head-r">
        {unlisted && token ? (
          <UnlistedManageBar client:load token={token} shareUrl={shareUrl} />
        ) : !isUpload ? (
          <a class="rescan-btn" href={rescanHref}>
            <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M13.5 8a5.5 5.5 0 1 1-1.6-3.9M13.5 2v3h-3"></path></svg>
            <span>Re-scan</span>
            <span class="rs-meta">~30s</span>
          </a>
        ) : null}
      </div>
    </div>
  </div>
</header>

{isUpload ? (
  <UploadReport client:load run={run} ruleCount={ruleCount} unlisted={unlisted} token={token} />
) : (
  <>
    <section class="sr-stat-band">
      <div class="container">
        <div class="sr-stat-grid">
          <div class={`score-cell ${tierLetter}`.trim()}>
            <div class="sc-label"><span class="lab">Repo consolidated score</span><span class="tag">{run.capability_count} discovered</span></div>
            <div class="sr-big">{score}<span class="denom">/100</span></div>
            <div class="dots">
              {tierLetter && <span class={`dot-${tierLetter}`}>{'●'.repeat(dotsFilled)}</span>}<span class="dot-off">{'○'.repeat(10 - dotsFilled)}</span>
            </div>
            {scored ? <BandPill tier={scored} label={`${tierName} band`} /> : <span class="band-pill unscoped">UNSCORED</span>}
            <p class="sc-note">
              Mean of the <b>{run.capability_count} capability score{run.capability_count === 1 ? '' : 's'}</b> below.
              {lowest && <> Lowest is <b>{lowest.name} · {lowest.aggregate_score}</b>.</>}
            </p>
          </div>

          <div class="sr-facts">
            <span class="sb-eyebrow">This scan</span>
            <div class="fact"><span>Capabilities</span><b>{tallyText || `${run.capability_count} discovered`}</b></div>
            <div class="fact"><span>Detectors</span><b>{ruleCount} checks · 5 categories</b></div>
            <div class="fact"><span>Findings</span><b>{warnFindings} warning{warnFindings === 1 ? '' : 's'} · {highFindings} high</b></div>
            <div class="fact"><span>Engine</span><b>SaferSkills {run.engine_version.slice(0, 7)}</b></div>
            <div class="fact"><span>Rubric</span><b>{run.rubric_version.slice(0, 7)}</b></div>
            <a class="sr-method" href="/methodology">View methodology →</a>
          </div>
        </div>
      </div>
    </section>

    <section class="sr-main">
      <div class="container">
        <div class="sr-block">
          <ScanReportView client:load run={run} shareUrl={shareUrl} />
        </div>
      </div>
    </section>

    <ShareResultBand
      client:visible
      unlisted={unlisted}
      scanId={run.id}
      score={score}
      tier={scored}
      slug={undefined}
      sub={shareSub}
      foot={shareFoot}
      scanIdShort={scanIdLabel}
    />
  </>
)}
