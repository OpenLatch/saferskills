---
// Shared COMPLETED-report body for both /scans/<run_id> (public) and
// /scans/r/<token> (unlisted). Renders one of two layouts:
//   • rich single-capability upload layout (mockups 3 + 4) when the run is an
//     upload with exactly one capability — score box + provenance + source/score
//     tabs + install/pkg cards + README/locked badge;
//   • the multi-capability cap-list layout (mockups 5 + 6) otherwise — the
//     unchanged I-03 GitHub report body, made visibility-aware.
// Unlisted runs additionally get the private banner, eyebrow, manage bar, expiry
// pill, and (single-cap) the "badge locked until promote" band. The page owns
// the anti-leakage headers + Base/nav/footer; this component is body-only.
import BandPill from '@ui/components/atoms/BandPill.tsx'
import Breadcrumb from '@ui/components/atoms/Breadcrumb.tsx'
import EmbedBadgeBox from '@ui/components/molecules/EmbedBadgeBox.tsx'

import CapabilityReportTabs from '@/components/scan/CapabilityReportTabs.tsx'
import ScanReportView from '@/components/scan/ScanReportView.tsx'
import UnlistedManageBar from '@/components/scan/UnlistedManageBar.tsx'
import ExpiryCountdown from '@/components/scan/ExpiryCountdown.tsx'
import { kindTag } from '@/components/catalog/constants'
import { itemDownloadUrl } from '@/lib/api/items'
import type { ScanRunReportDetail } from '@/lib/api/scans'
import { unlistedDownloadUrl } from '@/lib/api/scans'
import { reportIdentity } from '@/lib/report-identity'
import { scoredTier, TIER_TO_STRIPE } from '@/lib/tier'

interface Props {
  run: ScanRunReportDetail
  shareUrl: string
  ruleCount: number
  /** Rendered via the capability-URL route — adds the private chrome. */
  unlisted?: boolean
  /** The capability-URL token (masked in the eyebrow, used for the .zip + manage bar). */
  token?: string
}

const { run, shareUrl, ruleCount, unlisted = false, token } = Astro.props

const { isUpload, uploadName, baseTitle } = reportIdentity(run)
const isRich = isUpload && run.capability_count === 1
const cap = run.capabilities[0] ?? null

const kindLabel = cap
  ? cap.kind === 'mcp_server'
    ? 'MCP server'
    : cap.kind === 'skill'
      ? 'Agent Skill'
      : kindTag(cap.kind)
  : 'Artifact'

const shaFull = run.artifact_sha256 ?? ''
const shaShort = shaFull ? `${shaFull.slice(0, 4)}…${shaFull.slice(-4)}` : '—'
const scanIdShort = `scn_${run.id.replace(/-/g, '').slice(0, 12)}`
const uploadExt = (run.uploaded_filename ?? '').toLowerCase().endsWith('.zip') ? '.zip' : 'file'

const fmtDate = (iso: string) =>
  new Date(iso).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })

// Consolidated facts (every value from the run DTO).
const scored = scoredTier(run.repo_tier)
const tierLetter = scored ? TIER_TO_STRIPE[scored] : ''
const tierName = scored ? scored.charAt(0).toUpperCase() + scored.slice(1) : 'Unscored'
const score = run.repo_aggregate_score
const dotsFilled = Math.max(0, Math.min(10, Math.round(score / 10)))

const caps = run.capabilities
const totalFindings = caps.reduce((n, c) => n + c.findings_summary.total, 0)
const highFindings = caps.reduce((n, c) => n + c.findings_summary.critical + c.findings_summary.high, 0)
const warnFindings = totalFindings - highFindings
const lowest = caps.length
  ? caps.reduce((a, b) => (b.aggregate_score < a.aggregate_score ? b : a))
  : null

const tallyText = Object.entries(run.kind_tally)
  .filter(([, n]) => n > 0)
  .map(([k, n]) => `${n} ${kindTag(k).toLowerCase()}${n === 1 ? '' : 's'}`)
  .join(' · ')

const latencySeconds = Math.max(0, Math.round(run.latency_ms / 1000))
const rescanHref = run.github_url ? `/scan?prefill=${encodeURIComponent(run.github_url)}` : '/scan'
const githubHost = run.github_url
  ? run.github_url.replace(/^https?:\/\//, '').replace(/\/$/, '')
  : ''

// Masked token for the private eyebrow — never the literal token (D-UP-14).
const maskedToken = token ? `${token.slice(0, 10)}` : ''

// .zip download target: public uploads serve via the canonical item; unlisted via
// the token-gated route (the public /items/<slug>/download 404s for shadow rows).
const zipHref = unlisted && token
  ? unlistedDownloadUrl(token)
  : cap
    ? itemDownloadUrl(cap.catalog_slug, run.download?.scan_id ?? undefined)
    : '#'
const zipSizeKb = run.download ? (run.download.byte_size / 1024).toFixed(1) : null
---

{unlisted && (
  <section class="private-banner" data-screen-label="Private banner">
    <div class="container">
      <div class="pb-inner">
        <span class="pb-lock" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="11" width="16" height="10"></rect><path d="M7.5 11 V7.5 a4.5 4.5 0 0 1 9 0 V11"></path></svg>
        </span>
        <p class="pb-text"><b>Private — only people with this link can see this.</b> Not listed in the catalog or search. Anyone with the link can also delete or publish it.</p>
      </div>
    </div>
  </section>
)}

<header class={`page-head sk-head sr-head${isRich ? ' sk-head--rich' : ''}`}>
  <div class="container">
    {unlisted ? (
      <span class="ph-eyebrow">Report · Private · /scans/r/{maskedToken}…</span>
    ) : isRich ? (
      <Breadcrumb items={[{ label: 'Scan', href: '/scan' }, { label: 'Uploaded artifact' }, { label: baseTitle }]} />
    ) : (
      <Breadcrumb items={[{ label: 'Scan', href: '/scan' }, { label: isUpload ? 'Uploaded artifact' : 'Repository' }, { label: baseTitle }]} />
    )}

    <div class="sr-head-row">
      <div class="sr-head-l">
        <h1 class="ph-title">{baseTitle}<span class="script">— scan {isRich ? 'result' : 'complete'}</span></h1>
        {isRich ? (
          <p class="ph-lede">Independently scanned by SaferSkills from an uploaded artifact. Below is the consolidated security score, the full rubric breakdown, and the exact bytes we scored.</p>
        ) : (
          <p class="ph-lede">{run.capability_count} capabilit{run.capability_count === 1 ? 'y' : 'ies'} discovered · scored against {ruleCount} detectors across 5 categories.</p>
        )}
        <div class="sr-head-meta sk-head-meta">
          {isUpload ? (
            <>
              <span class="up-chip">Uploaded artifact</span>
              <span class="dot">·</span>
              <span>{kindLabel}</span>
              <span class="dot">·</span>
              <span>SHA-256 {shaShort}</span>
              <span class="dot">·</span>
              <span>uploaded {fmtDate(run.scanned_at)}</span>
            </>
          ) : (
            <>
              <span class="by">scanned <b>{fmtDate(run.scanned_at)}</b></span>
              <span class="dot">·</span>
              <span>{latencySeconds}s · {ruleCount} detectors</span>
              <span class="dot">·</span>
              <a href={run.github_url} target="_blank" rel="noopener">{githubHost}</a>
            </>
          )}
          {unlisted && run.expires_at && (
            <>
              <span class="dot">·</span>
              <ExpiryCountdown client:idle expiresAt={run.expires_at} variant="pill" />
            </>
          )}
        </div>
      </div>
      <div class="sr-head-r">
        {unlisted && token ? (
          <UnlistedManageBar client:load token={token} shareUrl={shareUrl} />
        ) : !isUpload ? (
          <a class="rescan-btn" href={rescanHref}>
            <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M13.5 8a5.5 5.5 0 1 1-1.6-3.9M13.5 2v3h-3"></path></svg>
            <span>Re-scan</span>
            <span class="rs-meta">~30s</span>
          </a>
        ) : null}
      </div>
    </div>
  </div>
</header>

{isRich ? (
  <>
    <section class="sk-stat-band">
      <div class="container">
        <div class="sk-stat-grid">
          <div class="sk-scorebox">
            <div class="sb-score">
              <span class="sb-eyebrow">Security score</span>
              <div class="sb-big">{score}<span class="sb-denom">/100</span></div>
              <div class="dots">
                {tierLetter && <span class={`dot-${tierLetter}`}>{'●'.repeat(dotsFilled)}</span>}<span class="dot-off">{'○'.repeat(10 - dotsFilled)}</span>
              </div>
              {scored ? <BandPill tier={scored} label={`${tierName} band`} /> : <span class="band-pill unscoped">UNSCORED</span>}
            </div>
            <div class="sb-facts">
              <span class="sb-eyebrow">This scan</span>
              <div class="fact"><span>Source</span><b>Uploaded artifact</b></div>
              <div class="fact"><span>Scanned</span><b>{fmtDate(run.scanned_at)}</b></div>
              <div class="fact"><span>Detectors</span><b>{ruleCount} checks · 5 categories</b></div>
              <div class="fact"><span>Findings</span><b>{warnFindings} warning{warnFindings === 1 ? '' : 's'} · {highFindings} high</b></div>
              <div class="fact"><span>Engine</span><b>rubric {run.rubric_version.slice(0, 7)}</b></div>
              <a class="sb-method" href="/methodology">View methodology →</a>
            </div>
          </div>

          <div class="sk-installbox">
            <span class="sb-eyebrow">Provenance</span>
            <div class="ins-row"><span>Source</span><b>Uploaded&nbsp;{uploadExt}</b></div>
            <div class="ins-row"><span>SHA-256</span><b>{shaShort}</b></div>
            <div class="ins-row"><span>Scan ID</span><b>{scanIdShort}</b></div>
            <div class="ins-row"><span>Signed by</span><b>openlatch-audit-key-v1</b></div>
            <div class="ins-distrib">
              <div class="legend" style="justify-content:flex-start; gap:0;"><span>Content-addressed · permanent · re-scan only by re-upload</span></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="sk-main">
      <div class="container">
        <div class="sk-grid">
          {cap && <CapabilityReportTabs client:load cap={cap} manifest={run.manifest ?? null} />}

          <aside class="sk-col-side">
            <div class="side-card install-card">
              <h4>Scanned artifact</h4>
              <p class="install-note">Scanned from an uploaded artifact — no install command. Download the exact bytes we scored:</p>
              <div class="install-cta">
                <a class="btn primary sm" href={zipHref} download>⤓ Download scanned bytes (.zip)</a>
                <span class="zip-meta">{uploadName}{zipSizeKb ? ` · ${zipSizeKb} KB` : ''}</span>
              </div>
              <div class="install-count">
                <span class="ic-num">90d+</span>
                <span class="ic-lbl">{unlisted ? 'unlisted uploads expire after 90 days' : 'public uploads are permanent & reproducible'}</span>
              </div>
            </div>

            <div class="side-card pkg-card">
              <h4>Artifact</h4>
              <dl class="pkg-dl">
                <div><dt>Detected</dt><dd>{kindLabel}</dd></div>
                <div><dt>SHA-256</dt><dd>{shaShort}</dd></div>
                {zipSizeKb && <div><dt>Size</dt><dd>{zipSizeKb} KB</dd></div>}
                <div><dt>Uploaded</dt><dd>{fmtDate(run.scanned_at)}</dd></div>
                <div><dt>Repository</dt><dd>N/A — uploaded artifact</dd></div>
                <div><dt>Scan ID</dt><dd>{scanIdShort}</dd></div>
              </dl>
              <a class="pkg-gh" href="/methodology">How scoring works →</a>
            </div>
          </aside>
        </div>
      </div>
    </section>

    {unlisted ? (
      <section class="badge-band" data-screen-label="Private status + metadata">
        <div class="container">
          <div class="badge-wrap">
            <div class="bw-l">
              <span class="sb-eyebrow">Private link</span>
              <h3>This scan is unlisted</h3>
              <p>It is reachable only by its secret link — not indexed, not in the catalog. Promote it to public to make it shareable and badge-embeddable.</p>
            </div>
            <div class="bw-r">
              <div class="badge-locked">
                <span class="bl-lock" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="11" width="16" height="10"></rect><path d="M7.5 11 V7.5 a4.5 4.5 0 0 1 9 0 V11"></path></svg>
                </span>
                <p>A public README badge becomes available once you <b>promote this scan to public</b>. While unlisted, the result stays reachable only by its secret link.</p>
              </div>
              <div class="bw-foot">Identified by content hash; reproducible by re-running rubric {run.rubric_version.slice(0, 7)} against the same bytes. &nbsp;·&nbsp; {scanIdShort}</div>
            </div>
          </div>
        </div>
      </section>
    ) : (
      <section class="badge-band" data-screen-label="README badge embed">
        <div class="container">
          <div class="badge-wrap">
            <div class="bw-l">
              <span class="sb-eyebrow">Share this result</span>
              <h3>Embed the badge in your README</h3>
              <p>Public uploads are permanent and reproducible — the badge resolves to this scan by its content hash.</p>
            </div>
            <div class="bw-r">
              <EmbedBadgeBox client:visible scanId={run.id} score={score} slug={cap?.catalog_slug} />
              <div class="bw-foot">Identified by content hash; reproducible by re-running rubric {run.rubric_version.slice(0, 7)} against the same bytes. &nbsp;·&nbsp; {scanIdShort}</div>
            </div>
          </div>
        </div>
      </section>
    )}
  </>
) : (
  <>
    <section class="sr-stat-band">
      <div class="container">
        <div class="sr-stat-grid">
          <div class={`score-cell ${tierLetter}`.trim()}>
            <div class="sc-label"><span class="lab">Repo consolidated score</span><span class="tag">{run.capability_count} discovered</span></div>
            <div class="sr-big">{score}<span class="denom">/100</span></div>
            <div class="dots">
              {tierLetter && <span class={`dot-${tierLetter}`}>{'●'.repeat(dotsFilled)}</span>}<span class="dot-off">{'○'.repeat(10 - dotsFilled)}</span>
            </div>
            {scored ? <BandPill tier={scored} label={`${tierName} band`} /> : <span class="band-pill unscoped">UNSCORED</span>}
            <p class="sc-note">
              Mean of the <b>{run.capability_count} capability score{run.capability_count === 1 ? '' : 's'}</b> below.
              {lowest && <> Lowest is <b>{lowest.name} · {lowest.aggregate_score}</b>.</>}
            </p>
          </div>

          <div class="sr-facts">
            <span class="sb-eyebrow">This scan</span>
            <div class="fact"><span>Capabilities</span><b>{tallyText || `${run.capability_count} discovered`}</b></div>
            <div class="fact"><span>Detectors</span><b>{ruleCount} checks · 5 categories</b></div>
            <div class="fact"><span>Findings</span><b>{warnFindings} warning{warnFindings === 1 ? '' : 's'} · {highFindings} high</b></div>
            <div class="fact"><span>Engine</span><b>SaferSkills {run.engine_version.slice(0, 7)}</b></div>
            <div class="fact"><span>Rubric</span><b>{run.rubric_version.slice(0, 7)}</b></div>
            <a class="sr-method" href="/methodology">View methodology →</a>
          </div>
        </div>
      </div>
    </section>

    <section class="sr-main">
      <div class="container">
        <div class="sr-block">
          <ScanReportView client:load run={run} shareUrl={shareUrl} />
        </div>
      </div>
    </section>
  </>
)}
