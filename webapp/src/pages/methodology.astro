---
export const prerender = true

import Base from '@/layouts/Base.astro'
import NavBar from '@ui/components/molecules/NavBar.tsx'
import { FALLBACK_GITHUB_STARS } from '@/data/launch-fallbacks'
import PageHead from '@ui/components/atoms/PageHead.tsx'
import PageRidge from '@ui/components/atoms/PageRidge.tsx'
import Eyebrow from '@ui/components/atoms/Eyebrow.tsx'
import RidgeStars from '@ui/components/atoms/RidgeStars.tsx'
import CtaBand from '@ui/components/molecules/CtaBand.tsx'
import Footer from '@ui/components/atoms/Footer.astro'
import { panelId } from '@ui/components/atoms/SegmentedTabs.tsx'

import MethodologyIndex from '@/generated/methodology/index.mdx'
import { ruleCount, ruleStats } from '@/generated/methodology/rule-count'
import { ruleRows } from '@/generated/methodology/rules-table'
import FormulaPanel from '@/components/methodology/FormulaPanel.astro'
import RuleFilter from '@/components/methodology/RuleFilter.tsx'
import AgentPackSection from '@/components/methodology/AgentPackSection.astro'
import MethodologyTabs from '@/components/methodology/MethodologyTabs.tsx'

import '@/styles/page-methodology.css'

// Prerendered page → this reflects the build-time URL (no query), so it is
// effectively always 'capability'. The live first-paint authority is the
// inline script below + the island's own URL read; this is only a hint.
const tabParam = Astro.url.searchParams.get('tab')
const initialTab = tabParam === 'agent' ? 'agent' : 'capability'
---
<Base
  title="Methodology — SaferSkills"
  description={`The full SaferSkills detection methodology — ${ruleCount} deterministic rules across 5 categories. Every claim ties to a specific rule, a rubric version, and a hashed evidence pointer. Reproducible by any third party offline.`}
>
  {/* Mark JS active before paint so the reveal CSS's hidden start state only
      applies when the IntersectionObserver below can undo it. */}
  <script is:inline>document.documentElement.classList.add('js-anim')</script>

  <NavBar client:idle ghCount={FALLBACK_GITHUB_STARS} activePath={Astro.url.pathname} />

  <PageHead
    eyebrow="METHODOLOGY · 05 · /METHODOLOGY"
    title="What we check & how it's weighted."
    lede="One methodology, two scan modes — static capability rules and the dynamic agent-scan pack. Every claim ties to a specific rule, a specific rubric version, and a specific finding's hashed evidence. Reproducible by any third party offline."
  />
  <PageRidge variant="mesh" label="— /METHODOLOGY —" />

  {/* ─────────── Capability rules / Agent pack — ONE shared band ───────────
      Both panels render on the same --flat surface so switching modes never
      changes the background. The island toggles the SSR'd panels' `hidden`. */}
  <section class="page-section page-section--flat" id="methodology-tabs">
    <div class="container">
      <MethodologyTabs client:idle initialTab={initialTab} />

      {/* Capability rules — 55-rule catalog → scoring formula reference */}
      <div
        class="method-panel"
        data-tab="capability"
        role="tabpanel"
        id={panelId('methodtab', 'capability')}
        aria-labelledby="methodtab-tab-capability"
      >
        <article class="methodology-prose" id="rules">
          <Eyebrow withRule>RULES</Eyebrow>
          <h2 class="prose-h2">The rules.</h2>
          <p>
            Every check we run is spelled out here — what it looks for, why it
            matters, how serious it is, and how to fix it, with each rule mapped to
            the OWASP LLM Top 10, MITRE ATLAS, and CWE where it applies. Search by
            name, severity, or framework, then export the list as CSV.
          </p>
        </article>
        <RuleFilter client:idle groups={ruleStats} total={ruleCount} rows={ruleRows} targetId="rules-index" />
        <div class="rules-index" id="rules-index">
          <MethodologyIndex />
        </div>

        {/* Scoring formula — the "how it's weighted" reference, trailing the catalog */}
        <div id="scoring-formula">
          <FormulaPanel />
        </div>
      </div>

      {/* Agent pack — scoring lead → AS-NN behavioral catalog */}
      <div
        class="method-panel"
        data-tab="agent"
        role="tabpanel"
        id={panelId('methodtab', 'agent')}
        aria-labelledby="methodtab-tab-agent"
        hidden
      >
        <AgentPackSection />
      </div>

      {/* Pre-paint first-paint authority. The page is prerendered → the static
          HTML defaults to the Capability panel; this corrects panels + control
          BEFORE paint for a `?tab=agent` / `#agent-pack` deep-link (no flash).
          Placed AFTER the panels + control so both exist when it runs; the
          island re-asserts the same split idempotently on hydration. */}
      <script is:inline>
        ;(function () {
          try {
            var params = new URLSearchParams(window.location.search)
            var active =
              params.get('tab') === 'agent' || window.location.hash === '#agent-pack'
                ? 'agent'
                : 'capability'
            var panels = document.querySelectorAll('.method-panel[data-tab]')
            for (var i = 0; i < panels.length; i++) {
              panels[i].hidden = panels[i].getAttribute('data-tab') !== active
            }
            var tabs = document.querySelectorAll('#methodology-tabs [role="tab"]')
            for (var j = 0; j < tabs.length; j++) {
              var on = tabs[j].id === 'methodtab-tab-' + active
              tabs[j].setAttribute('aria-selected', on ? 'true' : 'false')
              tabs[j].setAttribute('tabindex', on ? '0' : '-1')
              tabs[j].classList.toggle('on', on)
            }
          } catch (e) {}
        })()
      </script>
    </div>
  </section>

  <RidgeStars label="— REPRODUCIBILITY —" />

  {/* ─────────── Reproducibility (shared — applies to either mode) ─────────── */}
  <section class="page-section page-section--grid" id="reproducibility">
    <div class="container">
      <article class="methodology-prose">
        <Eyebrow withRule>REPRODUCIBILITY</Eyebrow>
        <h2 class="prose-h2">Reproducibility.</h2>
        <p>
          Run the same code through SaferSkills twice and you get the same result —
          every time. Scores come from fixed, published rules, never from an AI model
          making a judgment call, so anyone can re-check a verdict for themselves and
          reach the identical answer. No account, no API key, nothing to take on faith.
        </p>
        <p>
          <strong>No black-box findings.</strong> When a check flags something, the
          report shows exactly what was found, where, and which rule caught it — so you
          can see the reasoning, confirm it yourself, and fix the issue.
        </p>
      </article>
    </div>
  </section>

  <RidgeStars label="— VENDOR APPEALS —" />

  {/* ─────────── Vendor right-of-reply (shared — applies to either mode) ─────────── */}
  <section class="page-section page-section--flat" id="vendor-appeals">
    <div class="container">
      <article class="methodology-prose">
        <Eyebrow withRule>VENDOR APPEALS</Eyebrow>
        <h2 class="prose-h2">Vendor right-of-reply.</h2>
        <p>
          Every public verdict is appealable. Maintainers commit a verification
          token to <code>.saferskills/verify.txt</code> in their repo; once verified,
          they can submit a public response that appears alongside their findings.
          Re-scans triggered within 1 hour of any push.
        </p>
        <p>
          The vendor right-of-reply form at
          <code>/items/&lt;slug&gt;/respond</code> walks through the verification
          flow. Findings are never silently deleted — appealed findings carry the
          appeal outcome and rationale in the public record.
        </p>
      </article>
    </div>
  </section>

  <CtaBand
    client:visible
    title="Audit the pieces. Scan the whole. Decide."
    lead="Try the methodology on your own code — ~30 seconds, no account, full report at a permalink."
    primaryAction={{ label: 'Scan a GitHub repo', href: '/scan' }}
    secondaryAction={{ label: 'Browse capabilities', href: '/capabilities' }}
  />

  <Footer />

  {/* Foldable category groups — the .rg-head button toggles .is-collapsed on
      its section (grid-rows collapse handled in CSS). No-JS leaves every group
      expanded. Event-delegated so it covers all generated groups. */}
  <script is:inline>
    ;(function () {
      document.addEventListener('click', function (ev) {
        var head = ev.target.closest && ev.target.closest('.rg-head')
        if (!head) return
        var group = head.closest('.rule-group')
        if (!group) return
        var collapsed = group.classList.toggle('is-collapsed')
        head.setAttribute('aria-expanded', String(!collapsed))
      })
    })()
  </script>

  {/* Entrance reveal — adds `.is-visible` to each `[data-reveal]` (just the
      formula panel) as it scrolls into view, firing the weight-bar fill.
      No-ops under reduced-motion (CSS keeps bars at rest size) and reveals
      immediately where IntersectionObserver is unavailable. */}
  <script is:inline>
    ;(function () {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return
      var els = document.querySelectorAll('[data-reveal]')
      if (!('IntersectionObserver' in window)) {
        els.forEach(function (el) { el.classList.add('is-visible') })
        return
      }
      var io = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible')
              io.unobserve(e.target)
            }
          })
        },
        { threshold: 0.12, rootMargin: '0px 0px -6% 0px' }
      )
      els.forEach(function (el) { io.observe(el) })
    })()
  </script>
</Base>
