---
export const prerender = true

import Base from '@/layouts/Base.astro'
import NavBar from '@ui/components/molecules/NavBar.tsx'
import Button from '@ui/components/atoms/Button.tsx'
import Footer from '@ui/components/atoms/Footer.astro'

import HeroActionCards from '@/components/homepage/HeroActionCards.astro'
import { getHomepageData } from '@/lib/homepage'
import { ruleCount as methodologyRuleCount } from '@/generated/methodology/rule-count'

import '@/styles/page-404.css'

// Same resolved view-model the homepage uses — live-with-fallback, so the FIND
// + AUDIT cards render correct values even with an empty catalog or a missing
// API. An error page needs no live-refresh island; build-time-with-fallback is
// authoritative here.
const data = await getHomepageData({ ruleCountFallback: methodologyRuleCount })
---
<Base
  title="Page not found — SaferSkills"
  description="We can't find that skill, MCP, or page. Search the catalog, scan a new skill, or head back home."
  bodyClass="va"
>
  <NavBar client:idle ghCount={data.githubStars} activePath={Astro.url.pathname} />

  <main class="nf-band">
    <div class="container">
      <div class="nf-eyebrow">404 · Not Found</div>
      <h1>We can't find that <span class="mk">skill, MCP, or page</span>.</h1>
      <p class="nf-lede">
        It may have been moved, renamed, or never existed. Search the catalog,
        scan a new skill, or head back home.
      </p>

      <div class="nf-cards">
        <HeroActionCards data={data} />
      </div>

      <div class="nf-home-row">
        <Button as="a" href="/" size="lg" className="nf-home">
          <span class="nf-arrow" aria-hidden="true">←</span> Or take me back home
        </Button>
      </div>
    </div>
  </main>

  <Footer />
</Base>
