---
export const prerender = true

import Base from '@/layouts/Base.astro'
import NavBar from '@ui/components/molecules/NavBar.tsx'
import { FALLBACK_GITHUB_STARS } from '@/data/launch-fallbacks'
import PageHead from '@ui/components/atoms/PageHead.tsx'
import PageRidge from '@ui/components/atoms/PageRidge.tsx'
import RidgeStars from '@ui/components/atoms/RidgeStars.tsx'
import CtaBand from '@ui/components/molecules/CtaBand.tsx'
import Footer from '@ui/components/atoms/Footer.astro'

import '@/styles/page-about.css'
---
<Base
  title="About — SaferSkills"
  description="SaferSkills is the public, independent security-scanning service for AI agents and the capabilities they run — skills, MCP servers, hooks, and plugins. We index them. We audit them. We scan the whole running agent. We publish the report. An OpenLatch project — open-source, methodology-driven."
>
  <NavBar client:idle ghCount={FALLBACK_GITHUB_STARS} activePath={Astro.url.pathname} />

  <PageHead
    eyebrow="ABOUT · 07 · /ABOUT"
    title="About SaferSkills."
    lede="A public, free, open-source security-scanning service for AI agents and the capabilities they run. We index them. We audit them. We scan the whole running agent. We publish the report."
  />
  <PageRidge variant="contour" label="— /ABOUT —" />

  {/* ─────────── Why we built this ─────────── */}
  <section class="page-section page-section--grid about-band">
    <div class="container">
      <h2 class="prose-h2">Why we built this.</h2>
      <p>
        AI agent skills, MCP servers, hooks, and plugins have exploded across eight
        platforms in eighteen months. There is no shared audit, no shared methodology,
        no shared trust signal. Every install is a leap of faith — and the data we have
        suggests that faith is misplaced.
      </p>

      <div class="about-stats">
        <div class="row headline">
          <span class="stat-num">36%</span>
          <div class="stat-body">
            <b>of AI agent skills tested contain prompt-injection patterns.</b>
            <cite>Snyk ToxicSkills · 2026</cite>
          </div>
        </div>
        <div class="row prose">
          <span class="stat-num">NO·1</span>
          <div class="stat-body">
            No public audit methodology existed for skills, MCPs, or hooks before
            SaferSkills. Every registry trusted vendors to self-certify.
          </div>
        </div>
        <div class="row prose">
          <span class="stat-num">NO·2</span>
          <div class="stat-body">
            Existing registries (mcp.so, Smithery, ClawHub, etc.) don't disclose what
            criteria — if any — they apply before listing a skill.
          </div>
        </div>
        <div class="row prose">
          <span class="stat-num">NO·3</span>
          <div class="stat-body">
            Verification of "works with my agent" is left entirely to the user. There is
            no install-time gate, no version-locked review, no reproducible audit.
          </div>
        </div>
      </div>

      <p>
        SaferSkills is the answer to that gap. Anyone submits a public GitHub URL; thirty
        seconds later, a deterministic security report appears at a permalink. The same
        open methodology also scans the whole running agent — not just the pieces it
        installs. The rules are open. The methodology is open. The findings cite a rule
        ID and a line of evidence. Vendors get a right-of-reply on every public verdict.
      </p>

      <p>
        Think VirusTotal, but for AI agents — audit the pieces, scan the whole agent.
      </p>
    </div>
  </section>

  <RidgeStars label="— FOUNDER · 02 —" />

  {/* ─────────── Founder ─────────── */}
  <section class="page-section page-section--flat about-band">
    <div class="container">
      <h2 class="prose-h2">Who's behind it.</h2>
      <div class="founder-card">
        <img
          class="avatar"
          src="/founder/luc-delsalle.webp"
          width="64"
          height="64"
          alt="Luc Delsalle"
          loading="lazy"
          decoding="async"
        />
        <div>
          <div class="name-row">
            <span class="name">Luc Delsalle</span>
            <span class="role">Founder &amp; CEO</span>
          </div>
          <p class="bio">
            20+ years in cybersecurity and enterprise infrastructure. Previously: CTO
            Ailevate · VP of Engineering Tenable (NASDAQ: TENB) · Co-Founder + CTO
            Alsid, identity security company acquired by Tenable. Deep background in
            identity security, attack-path analysis, and runtime enforcement.
          </p>
          <div class="links">
            <a href="https://github.com/ldelsalle" rel="noopener">github.com/ldelsalle</a>
            <span aria-hidden="true">·</span>
            <a href="https://linkedin.com/in/lucdelsalle" rel="noopener">linkedin.com/in/lucdelsalle</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <RidgeStars label="— REACH US · 03 —" />

  {/* ─────────── Reach us ─────────── */}
  <section class="page-section page-section--flat about-band" id="reach-us">
    <div class="container">
      <h2 class="prose-h2">How to reach us.</h2>
      <p>
        Email is the right channel for security disclosures, press, partnerships, and
        methodology proposals. Each address routes to a real person, not a contact-form
        queue.
      </p>

      <ul class="reach-list">
        <li>
          <span class="reach-label">Security</span>
          <span class="reach-desc">Vulnerability reports &amp; disclosures</span>
          <a class="reach-email" href="mailto:security@openlatch.ai">security@openlatch.ai</a>
        </li>
        <li>
          <span class="reach-label">Press</span>
          <span class="reach-desc">Media &amp; interview requests</span>
          <a class="reach-email" href="mailto:press@openlatch.ai">press@openlatch.ai</a>
        </li>
        <li>
          <span class="reach-label">General</span>
          <span class="reach-desc">Everything else</span>
          <a class="reach-email" href="mailto:hello@openlatch.ai">hello@openlatch.ai</a>
        </li>
        <li>
          <span class="reach-label">Methodology</span>
          <span class="reach-desc">Rule proposals &amp; scoring feedback</span>
          <a class="reach-email" href="mailto:methodology@openlatch.ai">methodology@openlatch.ai</a>
        </li>
      </ul>

      <aside class="outbound-note">
        <span class="on-label">Sending domain</span>
        <dl class="on-rows">
          <div class="on-row">
            <dt>From</dt>
            <dd>SaferSkills &lt;…@notifications.openlatch.ai&gt;</dd>
          </div>
          <div class="on-row">
            <dt>Reply-to</dt>
            <dd>any @openlatch.ai mailbox</dd>
          </div>
        </dl>
        <p class="on-prose">
          A single verified sending domain shared with OpenLatch keeps email
          infrastructure at one domain seat.
        </p>
      </aside>
    </div>
  </section>

  <CtaBand
    client:visible
    title="Run a scan."
    lead="Audit the pieces. Scan the whole. Decide. ~30 seconds. Free. No account. The report URL is bookmarkable and persists for 90 days."
    primaryAction={{ label: 'Scan a GitHub repo →', href: '/scan' }}
    secondaryAction={{ label: 'Browse catalog', href: '/catalog' }}
  />

  <Footer />
</Base>
