---
export const prerender = false

import Base from '@/layouts/Base.astro'
import NavBar from '@ui/components/molecules/NavBar.tsx'
import PageHead from '@ui/components/atoms/PageHead.tsx'
import PageRidge from '@ui/components/atoms/PageRidge.tsx'
import Footer from '@ui/components/atoms/Footer.astro'

import CatalogToolbar from '@/components/catalog/CatalogToolbar.tsx'
import CatalogFilterSide from '@/components/catalog/CatalogFilterSide.tsx'
import CatalogResultsList from '@/components/catalog/CatalogResultsList.tsx'
import { listCatalogItems, type ListItemsParams } from '@/lib/api/items'

import '@/styles/page-catalog.css'

const url = new URL(Astro.request.url)
const filters: ListItemsParams = {
  kind: url.searchParams.getAll('kind'),
  scan_tier: url.searchParams.getAll('scan_tier'),
  score_min: parseInt(url.searchParams.get('score_min') ?? '0', 10),
  score_max: parseInt(url.searchParams.get('score_max') ?? '100', 10),
  q: url.searchParams.get('q') ?? undefined,
  sort: (url.searchParams.get('sort') as ListItemsParams['sort']) ?? 'most_installed',
  cursor: url.searchParams.get('cursor'),
  limit: 25,
}

const response = await listCatalogItems(filters).catch(() => ({
  data: [],
  next_cursor: null,
  total_count: 0,
}))

const emptyVariant: 'empty-catalog' | 'no-match' =
  response.total_count === 0 ? 'empty-catalog' : 'no-match'
---

<Base
  title="Catalog — SaferSkills"
  description="Every AI skill, independently scanned. Unified catalog across 12+ registries."
>
  <NavBar client:idle />

  <PageHead
    eyebrow="CATALOG · 02 · /CATALOG"
    title="Browse skills, MCPs & plugins."
    lede="Unified index across mcp.so, Smithery, ClawHub, npm and 8 more registries. Filter by agent, band, and scan tier — every item independently audited."
  />
  <PageRidge variant="mesh" label="— /CATALOG —" />

  <CatalogToolbar
    client:load
    totalCount={response.total_count}
    initialQuery={filters.q ?? ''}
  />

  <section class="cat-split">
    <CatalogFilterSide
      client:idle
      initial={{
        kind: filters.kind ?? [],
        scoreMin: filters.score_min ?? 0,
        scoreMax: filters.score_max ?? 100,
        scanTier: filters.scan_tier ?? [],
      }}
    />
    <CatalogResultsList
      client:idle
      items={response.data}
      nextCursor={response.next_cursor}
      totalCount={response.total_count}
      emptyVariant={response.data.length === 0 ? emptyVariant : undefined}
    />
  </section>

  <Footer />
</Base>
