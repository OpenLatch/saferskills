---
// `/catalog` was renamed to `/capabilities` (the brand line is "every AI
// capability, independently scanned"). This thin SSR page issues a permanent
// 301 redirect, preserving any query string so filtered links like
// `/catalog?kind=skill` land on `/capabilities?kind=skill`.
export const prerender = false
return Astro.redirect(`/capabilities${Astro.url.search}`, 301)
---
