---
export const prerender = false

import Base from '@/layouts/Base.astro'
import NavBar from '@ui/components/molecules/NavBar.tsx'
import { FALLBACK_GITHUB_STARS } from '@/data/launch-fallbacks'
import RidgeRuler from '@ui/components/atoms/RidgeRuler.tsx'
import Footer from '@ui/components/atoms/Footer.astro'

import ScanConsole from '@/components/scan/ScanConsole.tsx'
import ScanMethodologyPreview from '@/components/scan/ScanMethodologyPreview.astro'
import ScanRecents from '@/components/scan/ScanRecents.astro'
import { listRecentSubmissionScans } from '@/lib/api/scans'
import { fetchPlatformStats } from '@/lib/api/stats'
import { fetchOrNull, pickCount } from '@/lib/fallback'
import { ruleCount as methodologyRuleCount } from '@/generated/methodology/rule-count'

import '@/styles/page-scan-submit.css'

const [recentScans, stats] = await Promise.all([
  listRecentSubmissionScans({ limit: 4 }).catch(() => []),
  fetchOrNull(fetchPlatformStats),
])

// Live detection-rule count with the generated-methodology count as fallback.
const ruleCount = pickCount(stats?.rule_count, methodologyRuleCount, 1)
---

<Base
  title="Scan — SaferSkills"
  description="Send an AI Skill, MCP or Hook — or upload your own files. Get a transparent security report in ~30 seconds. Free. No account."
>
  {/* Mark JS as active before the body paints so the reveal CSS's hidden
      initial state applies without a flash. No-JS visitors never get it. */}
  <script is:inline>document.documentElement.classList.add('js-anim')</script>

  <NavBar client:idle ghCount={stats?.github_stars ?? FALLBACK_GITHUB_STARS} activePath={Astro.url.pathname} />

  <header class="page-head">
    <div class="container">
      <div class="ph-eyebrow" data-reveal>SCAN · 03 · /SCAN</div>
      <h1 class="ph-title" data-reveal style="--reveal-delay: 90ms">Send a Skill, MCP or Hook — or <span class="mark">your own files</span>.<span class="script">— ~30s</span></h1>
      <p class="ph-lede" data-reveal style="--reveal-delay: 170ms">
        Drop a SKILL.md or a .zip, or paste a public GitHub URL. Independent audit across {ruleCount}
        detection rules. Free. No account. Public by default — go private with one toggle.
      </p>
    </div>
  </header>

  <RidgeRuler />

  <div class="scan-split">
    <section class="scan-form-pane" data-reveal>
      <ScanConsole client:load />
    </section>
    <aside class="scan-method-pane" data-reveal style="--reveal-delay: 120ms">
      <ScanMethodologyPreview />
    </aside>
  </div>

  <ScanRecents recentScans={recentScans} />

  <Footer />

  {/* Subtle entrance reveals — adds `.is-visible` as each `[data-reveal]`
      scrolls into view. Early-returns under reduced-motion (CSS already keeps
      those elements visible), and reveals everything immediately if
      IntersectionObserver is unavailable. */}
  <script is:inline>
    ;(function () {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return
      var els = document.querySelectorAll('[data-reveal]')
      if (!('IntersectionObserver' in window)) {
        els.forEach(function (el) { el.classList.add('is-visible') })
        return
      }
      var io = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible')
              io.unobserve(e.target)
            }
          })
        },
        { threshold: 0.12, rootMargin: '0px 0px -6% 0px' }
      )
      els.forEach(function (el) { io.observe(el) })
    })()
  </script>
</Base>
