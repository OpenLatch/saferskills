---
export const prerender = false

import Base from '@/layouts/Base.astro'
import NavBar from '@ui/components/molecules/NavBar.tsx'
import { FALLBACK_GITHUB_STARS } from '@/data/launch-fallbacks'
import { runtimeLabel } from '@ui/components/atoms/RuntimeMonogram.tsx'
import CtaBand from '@ui/components/molecules/CtaBand.tsx'
import Footer from '@ui/components/atoms/Footer.astro'

import AgentReport from '@/components/agent/AgentReport.tsx'
import AgentReportActions from '@/components/agent/AgentReportActions.tsx'
import AgentScanPollBoard from '@/components/agent/AgentScanPollBoard.tsx'

import { fetchAgentScanRunById } from '@/lib/api/agent-scans'
import { isPreGrade, isReportable } from '@/lib/api/agent-scan-types'
import { agentOgImage } from '@/lib/seo/og-image'
import { formatScannedAt } from '@/lib/agent/format'
import { fetchPlatformStats } from '@/lib/api/stats'
import { fetchOrNull, pickCount } from '@/lib/fallback'
import { ruleCount as methodologyRuleCount } from '@/generated/methodology/rule-count'

import '@/styles/page-scan-report.css'
import '@/styles/page-agent-report.css'

const { id } = Astro.params
if (!id) {
  return Astro.redirect('/404')
}

// DEV-only fixture loader — build against the fixture before the live
// grader is wired. Server-side + behind `import.meta.env.DEV`, which Vite strips
// to `false` in a prod build, dead-code-eliminating the dynamic import entirely.
let run = null
if (import.meta.env.DEV) {
  const fixtureKey = Astro.url.searchParams.get('fixture')
  const { isAgentFixtureKey, loadAgentFixture } = await import('@/lib/api/agent-scan-fixture')
  if (isAgentFixtureKey(fixtureKey)) run = loadAgentFixture(fixtureKey)
}
run ??= await fetchAgentScanRunById(id).catch(() => null)
if (!run) {
  return Astro.redirect('/404')
}

// An unlisted run is reachable ONLY via /agents/r/<token> (with the anti-leakage
// chrome), never the public URL — otherwise it could be indexed (mirrors /scans).
if (run.visibility === 'unlisted') {
  return Astro.redirect('/404')
}

const preGrade = isPreGrade(run.status)
const reportable = isReportable(run.status)
// aborted (or any non-reportable, non-pre-grade state) → generic 404.
if (!preGrade && !reportable) {
  return Astro.redirect('/404')
}

const stats = await fetchOrNull(fetchPlatformStats)
const ruleCount = pickCount(stats?.rule_count, methodologyRuleCount, 1)
const capCount = run.capabilities_present.length
const scoreLabel = run.score === null ? '' : ` ${run.score}/100`
const runtimeName = runtimeLabel(run.runtime)
---

<Base
  title={
    preGrade
      ? `Auditing ${run.agent_name} — SaferSkills`
      : `${run.agent_name} — agent scan${scoreLabel} — SaferSkills`
  }
  ogImage={agentOgImage(run.id, run.score, Astro.site)}
  description={
    preGrade
      ? `Live behavioral agent scan of ${run.agent_name} — an open adversarial pack is running.`
      : `Behavioral agent scan of ${run.agent_name}: ${run.band} band${scoreLabel}, ${run.findings.length} findings. Independent, methodology-open, free.`
  }
>
  <NavBar client:idle ghCount={stats?.github_stars ?? FALLBACK_GITHUB_STARS} activePath="/agents" />

  <header class="page-head sr-head">
    <div class="container">
      <span class="ph-eyebrow">Report · Agent Scan · /agents/{run.agent_name}</span>
      <div class="sr-head-row">
        <div class="sr-head-l">
          {preGrade ? (
            <h1 class="ph-title">Auditing {run.agent_name}<span class="script"> — in progress</span></h1>
          ) : (
            <h1 class="ph-title">{run.agent_name}<span class="script"> — agent scan complete</span></h1>
          )}
          <p class="ph-lede">
            We ran an open adversarial pack against the whole assembled agent — model, harness,
            all {capCount} capabilities, identity and permissions. Security here is emergent: no
            per-component score predicts it.
          </p>
          <div class="sr-head-meta">
            <span class="by">scanned <b>{formatScannedAt(run.scanned_at)}</b></span>
            <span class="dot">·</span>
            <span>{runtimeName} · {capCount} capabilities</span>
          </div>
        </div>
        <div class="sr-head-r">
          {!preGrade && <AgentReportActions client:load run={run} shareUrl={Astro.url.href} />}
        </div>
      </div>
    </div>
  </header>

  {preGrade ? (
    <AgentScanPollBoard client:load runId={run.id} target={run.agent_name} ruleCount={ruleCount} />
  ) : (
    <AgentReport client:load run={run} shareUrl={Astro.url.href} ruleCount={ruleCount} />
  )}

  <CtaBand
    client:visible
    title="Point the scanner at your own agent."
    lead="~40 seconds. Free. No account. Every scan produces a permanent, shareable Agent Report — and the badge to prove it."
    primaryAction={{ label: 'Scan an agent', href: '/scan' }}
    secondaryAction={{ label: 'Browse the index', href: '/agents' }}
  />

  <Footer />
</Base>
