---
export const prerender = false

import Base from '@/layouts/Base.astro'
import NavBar from '@ui/components/molecules/NavBar.tsx'
import { FALLBACK_GITHUB_STARS } from '@/data/launch-fallbacks'
import { runtimeLabel } from '@ui/components/atoms/RuntimeMonogram.tsx'
import ExpiryCountdown from '@/components/scan/ExpiryCountdown.tsx'
import CtaBand from '@ui/components/molecules/CtaBand.tsx'
import Footer from '@ui/components/atoms/Footer.astro'

import AgentReport from '@/components/agent/AgentReport.tsx'
import AgentReportActions from '@/components/agent/AgentReportActions.tsx'
import AgentScanPollBoard from '@/components/agent/AgentScanPollBoard.tsx'

import { fetchAgentScanUnlistedReport } from '@/lib/api/agent-scans'
import { isPreGrade, isReportable } from '@/lib/api/agent-scan-types'
import { formatScannedAt } from '@/lib/agent/format'
import { fetchPlatformStats } from '@/lib/api/stats'
import { fetchOrNull, pickCount } from '@/lib/fallback'
import { ruleCount as methodologyRuleCount } from '@/generated/methodology/rule-count'

import '@/styles/page-scan-report.css'
import '@/styles/page-agent-report.css'

// ── Anti-leakage headers — ALL THREE at the Astro PAGE level (security.md
// § Capability-URL anti-leakage). The browser/crawler/cache/SDK sees THIS
// response; the API headers are defense-in-depth. Set before any output.
Astro.response.headers.set('Referrer-Policy', 'no-referrer')
Astro.response.headers.set('Cache-Control', 'private, no-store')
Astro.response.headers.set('X-Robots-Tag', 'noindex, nofollow')

const { token } = Astro.params
if (!token) {
  return Astro.redirect('/404')
}

// DEV-only fixture loader (D-5.6-04) — server-side, stripped from prod by Vite.
let run = null
if (import.meta.env.DEV) {
  const fixtureKey = Astro.url.searchParams.get('fixture')
  const { isAgentFixtureKey, loadAgentFixture } = await import('@/lib/api/agent-scan-fixture')
  if (isAgentFixtureKey(fixtureKey)) run = loadAgentFixture(fixtureKey)
}

if (!run) {
  // `redirect: 'manual'` inside the helper: a promoted run answers 307 → we read
  // the Location and hand back a webapp path. Invalid/expired/deleted → generic
  // not_found (no oracle).
  const result = await fetchAgentScanUnlistedReport(token).catch(
    () => ({ status: 'not_found' as const }),
  )
  if (result.status === 'promoted') {
    return Astro.redirect(result.reportPath)
  }
  if (result.status === 'not_found') {
    return Astro.redirect('/404')
  }
  run = result.report
}

const preGrade = isPreGrade(run.status)
const reportable = isReportable(run.status)
if (!preGrade && !reportable) {
  return Astro.redirect('/404')
}

const stats = await fetchOrNull(fetchPlatformStats)
const ruleCount = pickCount(stats?.rule_count, methodologyRuleCount, 1)
const capCount = run.capabilities_present.length
const runtimeName = runtimeLabel(run.runtime)
---

<Base title={`Private agent scan — ${run.agent_name} — SaferSkills`} noindex={true}>
  <NavBar client:idle ghCount={stats?.github_stars ?? FALLBACK_GITHUB_STARS} activePath="/agents" />

  <section class="private-banner" data-screen-label="Private banner">
    <div class="container">
      <div class="pb-inner">
        <span class="pb-lock" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="11" width="16" height="10"></rect><path d="M7.5 11 V7.5 a4.5 4.5 0 0 1 9 0 V11"></path></svg>
        </span>
        <p class="pb-text"><b>Private — only people with this link can see this.</b> Not listed in the index or search. Anyone with the link can also delete or publish it.</p>
      </div>
    </div>
  </section>

  <header class="page-head sr-head">
    <div class="container">
      <span class="ph-eyebrow">Report · Private · /agents/r/&lt;token&gt;</span>
      <div class="sr-head-row">
        <div class="sr-head-l">
          {preGrade ? (
            <h1 class="ph-title">Auditing {run.agent_name}<span class="script"> — in progress</span></h1>
          ) : (
            <h1 class="ph-title">{run.agent_name}<span class="script"> — agent scan complete</span></h1>
          )}
          <p class="ph-lede">
            We ran an open adversarial pack against the whole assembled agent — model, harness,
            all {capCount} capabilities, identity and permissions. This report is private — only
            people with this link can see it.
          </p>
          <div class="sr-head-meta">
            <span class="by">scanned <b>{formatScannedAt(run.scanned_at)}</b></span>
            <span class="dot">·</span>
            <span>{runtimeName} · {capCount} capabilities</span>
            {run.expires_at && (
              <>
                <span class="dot">·</span>
                <ExpiryCountdown client:idle expiresAt={run.expires_at} variant="pill" />
              </>
            )}
          </div>
        </div>
        <div class="sr-head-r">
          {!preGrade && (
            <AgentReportActions
              client:load
              run={run}
              shareUrl={Astro.url.href}
              unlisted={true}
              token={token}
            />
          )}
        </div>
      </div>
    </div>
  </header>

  {preGrade ? (
    <AgentScanPollBoard client:load token={token} target={run.agent_name} ruleCount={ruleCount} />
  ) : (
    <AgentReport
      client:load
      run={run}
      shareUrl={Astro.url.href}
      ruleCount={ruleCount}
      unlisted={true}
      token={token}
    />
  )}

  <div class="private-foot">
    <div class="container">
      <span>
        <span class="pf-lock" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.4" style="vertical-align:-2px;"><rect x="4" y="11" width="16" height="10"></rect><path d="M7.5 11 V7.5 a4.5 4.5 0 0 1 9 0 V11"></path></svg>
        </span>
        Not listed or linked anywhere, and marked <code>noindex</code> — but the link is the only protection. Losing it means losing access; sharing it shares full control. There is no recovery.
      </span>
    </div>
  </div>

  <CtaBand
    client:visible
    title="Point the scanner at your own agent."
    lead="Public reports are published permanently; unlisted ones expire in 90 days."
    primaryAction={{ label: 'Browse the agent index', href: '/agents' }}
    secondaryAction={{ label: 'Browse capabilities', href: '/capabilities' }}
  />

  <Footer />
</Base>
