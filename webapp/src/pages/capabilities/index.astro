---
export const prerender = false

import Base from '@/layouts/Base.astro'
import NavBar from '@ui/components/molecules/NavBar.tsx'
import { FALLBACK_GITHUB_STARS } from '@/data/launch-fallbacks'
import RidgeStars from '@ui/components/atoms/RidgeStars.tsx'
import Footer from '@ui/components/atoms/Footer.astro'

import CatalogApp from '@/components/catalog/CatalogApp.tsx'
import { stateFromSearchParams } from '@/components/catalog/constants'
import { fetchCatalogFacets, listCatalogItems, type CatalogListResponse } from '@/lib/api/items'
import { fetchPlatformStats } from '@/lib/api/stats'
import { fetchOrNull } from '@/lib/fallback'

import '@/styles/page-catalog.css'

const url = new URL(Astro.request.url)
const sp = url.searchParams

const initialState = stateFromSearchParams(sp)
const pageNum = initialState.page
const sort = initialState.sort

const PAGE_SIZE = 10

const EMPTY: CatalogListResponse = {
  data: [],
  next_cursor: null,
  total_count: 0,
  page: pageNum,
  total_pages: 1,
  page_size: PAGE_SIZE,
}

const [response, facets, stats] = await Promise.all([
  listCatalogItems({
    kind: initialState.kind,
    agent: initialState.agent,
    popularity_tier: initialState.popularityTier,
    scan_tier: initialState.scanTier,
    artifact_source: initialState.artifactSource || undefined,
    score_min: initialState.scoreMin,
    score_max: initialState.scoreMax,
    q: initialState.q || undefined,
    sort,
    page: pageNum,
    limit: PAGE_SIZE,
  }).catch(() => EMPTY),
  fetchOrNull(fetchCatalogFacets),
  fetchOrNull(fetchPlatformStats),
])

const totalIndexed = stats?.catalog_total ?? response.total_count
const registriesCount = stats?.registries_count ?? Object.keys(facets?.registry ?? {}).length
---

<Base
  title="Capabilities — SaferSkills"
  description="Every AI capability, independently scanned. Unified index across 12+ registries — filter by type, agent, band, and scan tier."
>
  <NavBar client:idle ghCount={stats?.github_stars ?? FALLBACK_GITHUB_STARS} activePath={Astro.url.pathname} />

  <header class="page-head page-head--compact">
    <div class="container">
      <div class="ph-eyebrow">CAPABILITIES · 02 · /CAPABILITIES</div>
      <h1 class="ph-title">Browse <span class="mark">{totalIndexed.toLocaleString()}</span> skills, MCPs &amp; plugins.</h1>
      <p class="ph-lede">
        Unified index across {registriesCount}+ registries — every item independently scanned.
      </p>
    </div>
  </header>

  <CatalogApp
    client:load
    initialState={initialState}
    initialData={response}
    initialFacets={facets}
  />

  <RidgeStars label="— END OF RESULTS · 04 —" />

  <Footer />
</Base>
