---
export const prerender = true

import Base from '@/layouts/Base.astro'
import NavBar from '@ui/components/molecules/NavBar.tsx'
import RotatingHeadline from '@ui/components/atoms/RotatingHeadline.tsx'
import CrosshairGrid from '@ui/components/atoms/CrosshairGrid.tsx'
import RidgePixel from '@ui/components/atoms/RidgePixel.tsx'
import RidgeStars from '@ui/components/atoms/RidgeStars.tsx'
import RidgeFlow from '@ui/components/atoms/RidgeFlow.tsx'
import InstallTabs from '@ui/components/molecules/InstallTabs.tsx'
import AgentMarquee from '@ui/components/molecules/AgentMarquee.tsx'
import WhyRow from '@ui/components/molecules/WhyRow.tsx'
import CtaBand from '@ui/components/molecules/CtaBand.tsx'
import Footer from '@ui/components/atoms/Footer.astro'

import TopoBand from '@/components/homepage/TopoBand.astro'
import WaveBand from '@/components/homepage/WaveBand.astro'
import FeedsMosaic from '@/components/homepage/FeedsMosaic.astro'
import DetectionBand from '@/components/homepage/DetectionBand.astro'
import PixelWave from '@/components/homepage/PixelWave.astro'
import HeroActionCards from '@/components/homepage/HeroActionCards.astro'
import HomepageLive from '@/components/homepage/HomepageLive.tsx'

import { SUPPORTED_AGENTS } from '@/data/homepage-constants'
import { getHomepageData } from '@/lib/homepage'
import { formatCount, formatSeconds } from '@/lib/format'
import { ruleCount as methodologyRuleCount } from '@/generated/methodology/rule-count'

import '@/styles/page-home.css'

// One resolved view-model — every metric is live-with-fallback (build-time
// correct even with an empty catalog + JS disabled). The `HomepageLive` island
// re-runs the same view-model on the client to keep it fresh between deploys.
const data = await getHomepageData({ ruleCountFallback: methodologyRuleCount })
---
<Base
  title="SaferSkills — Every AI capability, independently audited."
  bodyClass="va"
>
  <NavBar client:idle ghCount={data.githubStars} activePath={Astro.url.pathname} />

  {/* Live-refresh island — re-runs the homepage view-model client-side and
      patches the SSR DOM (scalars + Popular chips + recently-scanned feed). */}
  <HomepageLive client:only="react" initial={data} />

  {/* ─────────────────────────────────────────────────────────
       BAND 1 — HERO
       ───────────────────────────────────────────────────────── */}
  <section class="hero-band" data-screen-label="01 Hero">
    <CrosshairGrid client:idle spacing={40} />
    <div class="container">

      {/* Empty spacer preserves the vertical rhythm where the
          "12,847 INDEXED · LIVE — …" eyebrow used to sit. */}
      <div class="hero-top" aria-hidden="true"></div>

      <RotatingHeadline
        client:load
        base="Every AI capability, independently audited against"
        nouns={[
          'Prompt Injection',
          'PII Leaks',
          'Secrets Leaks',
          'Security Drift',
          'Rogue Obfuscation',
          'Tool Poisoning',
          'Supply Chain Attacks',
          'Destructive Commands',
        ]}
        trailing="."
        cycleMs={2600}
        fadeMs={320}
      />

      <p class="hero-lede">
        Send an AI Skill, MCP or Hook — get a transparent security report in thirty seconds.
        One unified catalog. One install command to manage capabilities across eight agents.
      </p>

      <div class="hero-cards">
        <HeroActionCards data={data} />
      </div>

      <ul class="hero-stats" aria-label="Headline stats">
        <li><b data-live-stat="catalog_total">{formatCount(data.catalogTotal)}</b> indexed</li>
        <li><b data-live-stat="median">{data.medianScore}</b>/100 median</li>
        <li><b data-live-stat="rule_count">{data.ruleCount}</b> detection rules</li>
        <li><b data-live-stat="p95">{formatSeconds(data.p95LatencyMs)}</b> p95 · free · no account</li>
      </ul>

    </div>

    {/* supported agents marquee — anchors the bottom of the hero */}
    <div class="supported-band">
      <AgentMarquee client:visible agents={SUPPORTED_AGENTS} />
    </div>
  </section>

  {/* ─────────────────────────────────────────────────────────
       BAND 2 — TOPOGRAPHIC RIDGE DIVIDER
       ───────────────────────────────────────────────────────── */}
  <TopoBand label="— HORIZON —" />

  {/* ─────────────────────────────────────────────────────────
       BAND 3 — INSTALL DEMO (dark terminal + sidebar agent picker)
       ───────────────────────────────────────────────────────── */}
  <section class="section install-band">
    <span class="ib-corner tl" aria-hidden="true"><span></span><span></span><span></span></span>
    <span class="ib-corner tr" aria-hidden="true"><span></span><span></span><span></span></span>
    <span class="ib-dashed" aria-hidden="true"></span>
    <PixelWave />
    <div class="container">
      <div class="install-head">
        <div>
          <div class="eyebrow">Install · 03</div>
          <h2>Scan, score &amp; install <span class="script">— any agent</span></h2>
        </div>
        <div class="lede">
          One binary, all eight agents, every OS. Audit what you already have, inspect
          any capability, and install or update skills, MCP servers &amp; hooks — safely,
          in a single command.
        </div>
      </div>

      <div style="margin-top: 32px;">
        <InstallTabs
          client:visible
          agents={SUPPORTED_AGENTS}
          defaultAgent="claude-code"
        />
        <div class="install-cap">
          ↑ Switch commands in the strip — install · scan · list · info · the agent rail picks your install target · also try
          <kbd style="font-family:var(--font-mono); font-size:10px; border:1px solid var(--color-line); padding:2px 6px;">⧉ Copy command</kbd>
          in the terminal header.
        </div>
      </div>
    </div>
  </section>

  {/* ─────────────────────────────────────────────────────────
       BAND 4 — RIDGE-PIXEL DIVIDER (install → feeds)
       ───────────────────────────────────────────────────────── */}
  <RidgePixel label="— FEEDS · 04 —" />

  {/* ─────────────────────────────────────────────────────────
       BAND 5 — FEEDS (Recently + Trending, 3×3 mosaic)
       ───────────────────────────────────────────────────────── */}
  <section class="section feeds-band">
    <div class="container">
      <FeedsMosaic recent={data.recent} trending={data.trending} />
    </div>
  </section>

  {/* ─────────────────────────────────────────────────────────
       BAND 6 — RIDGE-STARS DIVIDER (feeds → docs/why)
       ───────────────────────────────────────────────────────── */}
  <RidgeStars label="— WHY · 05 —" />

  {/* ─────────────────────────────────────────────────────────
       BAND 7 — WHY · 05 (man-page "Five reasons" docs-band)
       ───────────────────────────────────────────────────────── */}
  <section class="section docs-band">
    <div class="container">
      <div class="docs-head">
        <div class="l">
          <span>WHY(5)</span>
          <span>SaferSkills — Five Reasons It Earns The URL</span>
        </div>
      </div>
      <div class="docs-body">
        <div class="docs-side">
          <div class="sec">Name</div>
          <div class="name">Five reasons it earns the URL.</div>
          <div class="blurb">
            Find · Install · Verify · Monitor · Trust. Each pillar earns its row — and the
            metrics underneath.
          </div>
          <a class="pill" href="/methodology">Read the methodology →</a>
        </div>
        <div class="reasons-list">
          <WhyRow
            client:visible
            index="01"
            tag="find"
            bodyHtml="<b>Unified catalog across 12+ registries.</b><span>GitHub, npm, PyPI, MCP Registry, mcp.so, Smithery, Glama, PulseMCP, ClawHub, skillsmp, skills.sh, ClaudeSkills, SkillHub. One search instead of twelve.</span>"
            metaLinesHtml={[
              `<b data-live-stat="catalog_total">${formatCount(data.catalogTotal)}</b>indexed`,
              `updated hourly`,
            ]}
            arrow={{ label: 'open methodology', href: '/methodology' }}
          />
          <WhyRow
            client:visible
            index="02"
            tag="install"
            bodyHtml="<b>One command across all eight agent platforms.</b><span>macOS, Windows, Linux — no agent-specific config to learn. The score is re-verified at install time so you never install based on a stale page.</span>"
            metaLinesHtml={[
              `<b>8 / 8</b>agents`,
              `<b>3</b>OSes · one binary`,
            ]}
            arrow={{ label: 'npm package', href: 'https://www.npmjs.com/package/saferskills' }}
          />
          <WhyRow
            client:visible
            index="03"
            tag="verify"
            bodyHtml={`<b>Independent, transparent, open-source scoring.</b><span><b data-live-stat="rule_count">${data.ruleCount}</b> deterministic detection rules across five categories. Every finding cites a rule ID and an evidence line — not &quot;AI thinks this is bad,&quot; only reproducible facts.</span>`}
            metaLinesHtml={[
              `<b data-live-stat="rule_count">${data.ruleCount}</b>rules · Apache 2.0`,
              `community PRs welcome`,
            ]}
            arrow={{ label: 'rule index', href: '/methodology' }}
          />
          <WhyRow
            client:visible
            index="04"
            tag="monitor"
            bodyHtml="<b>Watch any skill.</b><span>Drift alerts when content changes. Risk alerts when the score drops ≥10 points. Weekly digests of trending items in your watched categories. Throttled, GDPR-compliant, one-click unsubscribe.</span>"
            metaLinesHtml={[
              `email-gated`,
              `<b>≤ 5</b>alerts / day`,
            ]}
            arrow={{ label: 'account self-deletion', href: '/docs#account' }}
          />
          <WhyRow
            client:visible
            index="05"
            tag="trust"
            bodyHtml="<b>No browser fingerprinting. No cross-site tracking.</b><span>Vendor right-of-reply with a 1-hour re-scan SLA. Privacy policy reviewed by external counsel; aggregated IP-ASN data only, fully disclosed.</span>"
            metaLinesHtml={[
              `privacy policy reviewed by counsel`,
            ]}
            arrow={{ label: 'privacy policy', href: '/privacy' }}
          />
        </div>
      </div>
      <div class="docs-foot">
        <span>SEE ALSO · <a class="link" href="/methodology">scoring(7)</a> · <a class="link" href="/privacy">privacy(5)</a> · <a class="link" href="https://github.com/OpenLatch/saferskills">github</a></span>
      </div>
    </div>
  </section>

  {/* ─────────────────────────────────────────────────────────
       BAND 8 — RIDGE-FLOW DIVIDER (docs/why → detection)
       ───────────────────────────────────────────────────────── */}
  <RidgeFlow label="— DETECTION · 06 —" />

  {/* ─────────────────────────────────────────────────────────
       BAND 9 — DETECTION (57 attacks marquee)
       ───────────────────────────────────────────────────────── */}
  <DetectionBand />

  {/* ─────────────────────────────────────────────────────────
       BAND 10 — WAVE-BAND DIVIDER (detection → CTA)
       ───────────────────────────────────────────────────────── */}
  <WaveBand />

  {/* ─────────────────────────────────────────────────────────
       BAND 11 — CTA-BAND
       ───────────────────────────────────────────────────────── */}
  <CtaBand
    client:visible
    title="Audit the pieces. Scan the whole. Decide."
    titleLines={['Audit the pieces.', 'Scan the whole.', 'Decide.']}
    lead="~30 seconds. Free. No account. The report URL is bookmarkable and persists for 90 days."
    primaryAction={{ label: 'Submit a capability →', href: '/scan' }}
    secondaryAction={{ label: 'Browse catalog', href: '/catalog' }}
  />

  <Footer />
</Base>
