---
/**
 * Native docs route — one prerendered page per `docs` collection
 * entry, rendered through DocsLayout. The rest param `[...slug]` also matches the
 * base (`slug: undefined` → `/docs/`), so the root `index.md` is served here too;
 * no separate index route. `build.format: 'directory'` (astro.config.mjs) emits
 * `dist/client/docs/<slug>/index.html` → `/docs/<slug>/` (URL parity with the
 * retired Starlight build). `prerender = true` opts this dynamic route into SSG
 * under the app's `output: 'server'` (same mechanism as /about, /methodology).
 */
export const prerender = true

import type { CollectionEntry } from 'astro:content'
import { getCollection, render } from 'astro:content'
import DocsLayout from '@/layouts/DocsLayout.astro'
import { idToSlug } from '@/lib/docs/nav'

export async function getStaticPaths() {
  const entries = await getCollection('docs')
  return entries.map((entry: CollectionEntry<'docs'>) => {
    const slug = idToSlug(entry.id)
    return { params: { slug: slug || undefined }, props: { entry } }
  })
}

const { entry } = Astro.props
const { Content, headings } = await render(entry)
---

<DocsLayout entry={entry} headings={headings}>
  <Content />
</DocsLayout>
