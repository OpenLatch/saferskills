---
export const prerender = true

import Base from '@/layouts/Base.astro'
import NavBar from '@ui/components/molecules/NavBar.tsx'
import { FALLBACK_GITHUB_STARS } from '@/data/launch-fallbacks'
import PageHead from '@ui/components/atoms/PageHead.tsx'
import PageRidge from '@ui/components/atoms/PageRidge.tsx'
import CtaBand from '@ui/components/molecules/CtaBand.tsx'
import Footer from '@ui/components/atoms/Footer.astro'

import { ruleCount } from '@/generated/methodology/rule-count'

import '@/styles/page-docs.css'
---
<Base
  title="Docs — SaferSkills"
  description="The SaferSkills CLI install docs ship in week 7-8. In the meantime, read the methodology behind every scan, view the README, or scan a repo yourself."
>
  <NavBar client:idle ghCount={FALLBACK_GITHUB_STARS} activePath={Astro.url.pathname} />

  <PageHead
    eyebrow="DOCS · 04 · /DOCS"
    title="CLI install docs coming with Track C."
    lede="The `npx saferskills install` command lands in week 7-8 of the build. In the meantime, read the methodology behind every scan, view the GitHub README, or scan a repo yourself."
  />
  <PageRidge variant="swell" label="— /DOCS —" />

  <section class="page-section page-section--grid docs-band">
    <div class="container">
      <div class="docs-cta-grid">
        <a class="docs-cta-card" href="/methodology">
          <span class="cta-eyebrow">METHODOLOGY</span>
          <h3 class="cta-title">The scoring rubric.</h3>
          <p class="cta-lede">
            {ruleCount} deterministic detection rules across 5 categories. Each rule has a
            documented trigger, severity, and false-positive history.
          </p>
          <span class="cta-action">Read methodology →</span>
        </a>
        <a
          class="docs-cta-card"
          href="https://github.com/OpenLatch/saferskills"
          rel="noopener"
          target="_blank"
        >
          <span class="cta-eyebrow">REPOSITORY</span>
          <h3 class="cta-title">README on GitHub.</h3>
          <p class="cta-lede">
            Apache-2.0. Open source. Issue tracker for rule proposals, vendor appeals,
            and contributions.
          </p>
          <span class="cta-action">View on GitHub →</span>
        </a>
        <a class="docs-cta-card" href="/scan">
          <span class="cta-eyebrow">TRY IT</span>
          <h3 class="cta-title">Run a scan.</h3>
          <p class="cta-lede">
            Send a capability for a static report — or scan a whole running agent.
          </p>
          <span class="cta-action">Scan now →</span>
        </a>
        <div class="docs-cta-card">
          <span class="cta-eyebrow">AGENT SCAN</span>
          <h3 class="cta-title">Scan a running agent.</h3>
          <p class="cta-lede">
            Point it at a deployed agent and run an open adversarial pack (OWASP Agentic
            + MITRE ATLAS) for a graded, shareable Agent Report.
          </p>
          <div class="cta-actions">
            <a class="cta-action" href="/methodology#agent-pack">Read the docs →</a>
            <a class="cta-action" href="/agents">Browse the agent index →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CtaBand
    client:visible
    title="Bookmark the methodology."
    lead="Every detection rule is documented, weighted, and linked to its source. No editorial spin."
    primaryAction={{ label: 'Read methodology', href: '/methodology' }}
    secondaryAction={{ label: 'Browse catalog', href: '/catalog' }}
  />

  <Footer />
</Base>
