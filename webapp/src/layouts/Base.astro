---
interface Props {
  title: string
  description?: string
  ogImage?: string
  /**
   * Extra class(es) appended to `<body>`. Used by the homepage to opt INTO the
   * `body.va` variant-A namespace so the homepage page-vocabulary
   * CSS in `webapp/src/styles/page-home.css` cascades, while other routes stay
   * untouched. Pages that don't need the namespace omit this prop.
   */
  bodyClass?: string
  /**
   * Unlisted/capability-URL pages (`/scans/r/<token>`) set this. It emits
   * `<meta name="robots" content="noindex, nofollow">` AND suppresses the
   * token-bearing `canonical` + `og:url` (both default to `Astro.url.href`,
   * which carries the secret token — a leak vector in shareable page source).
   * See `.claude/rules/security.md` § Capability-URL anti-leakage.
   */
  noindex?: boolean
}
const {
  title,
  description = 'Every AI capability, independently audited. Public, open-source trust scoring for skills, MCP servers, hooks, plugins, and rules across every agent platform.',
  ogImage,
  bodyClass,
  noindex = false,
} = Astro.props
import '@/styles/global.css'
import NavStars from '@/components/NavStars.tsx'
import JsonLd from '@/components/seo/JsonLd.astro'
import { organizationJsonLd } from '@/lib/jsonld'
const ogImageUrl = ogImage ?? new URL('/og-image.png', Astro.site).href
// Never put the token-bearing page URL in shareable meta on a noindex page.
const ogUrl = noindex ? new URL('/', Astro.site).href : Astro.url.href
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0D9488" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0F766E" media="(prefers-color-scheme: dark)" />

    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {!noindex && <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />}

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="SaferSkills — Every AI capability, independently audited." />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <title>{title}</title>

    {/* Site-wide Organization JSON-LD (SEO-T4). XSS-safe renderer; the publisher
        identity is page-independent. Per-page schemas (SoftwareApplication /
        BreadcrumbList) are emitted by the individual route templates. */}
    <JsonLd schema={organizationJsonLd()} />

    {/*
      FOUC-prevention: applies `<html class="dark">` BEFORE first paint.
      Reads `localStorage['ss-theme']` (light | dark | auto) → falls back to
      `prefers-color-scheme: dark`. Managed by the ThemeToggle atom.
    */}
    <script is:inline>
      ;(function () {
        var KEY = 'ss-theme'
        var stored = null
        try { stored = localStorage.getItem(KEY) } catch (e) {}
        var mode = stored || 'auto'
        var effective = mode
        if (mode === 'auto') {
          effective = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'
        }
        document.documentElement.classList.toggle('dark', effective === 'dark')
        document.documentElement.dataset.themeMode = mode
      })()
    </script>

    {/* Re-apply theme after Astro view transitions. */}
    <script is:inline>
      document.addEventListener('astro:after-swap', function () {
        var mode = document.documentElement.dataset.themeMode || 'auto'
        var effective = mode
        if (mode === 'auto') {
          effective = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'
        }
        document.documentElement.classList.toggle('dark', effective === 'dark')
      })
    </script>
  </head>
  <body class:list={['min-h-screen', 'flex', 'flex-col', bodyClass]}>
    <slot />

    {/* Site-wide live refresh for the NavBar GitHub-star count (patches every
        [data-live-stat="stars"] node). Position-independent.
        client:only — it renders null + is effect-only; SSR-ing it throws a React
        "Invalid hook call". It produces no SSR markup either way. The GhStar count
        span it patches carries suppressHydrationWarning (this island mounts eagerly
        and may write the count before NavBar's client:idle GhStar hydrates). */}
    <NavStars client:only="react" />

    {/*
      Observability bootstrap — env-checked init for Sentry + PostHog.
      No-ops when `PUBLIC_SENTRY_DSN` / `PUBLIC_POSTHOG_KEY` are unset.
      Idle-loaded so it never blocks the first paint.
    */}
    <script>
      import { initObservability } from '@/lib/observability'
      function start() {
        initObservability().catch(() => {
          /* observability is best-effort; never break the page */
        })
      }
      if ('requestIdleCallback' in window) {
        ;(window as Window & typeof globalThis).requestIdleCallback(start)
      } else {
        setTimeout(start, 200)
      }
    </script>
  </body>
</html>
