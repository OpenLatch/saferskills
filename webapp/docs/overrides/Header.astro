---
/**
 * Docs Header override — the real SaferSkills NavBar (PR1, docs chrome
 * integration). Makes `/docs/*` wear the exact same top bar as saferskills.ai
 * so the docs read as part of the site, not a third-party docs host.
 *
 * Layout: the shared `NavBar` React island fills the row; Starlight's Pagefind
 * `<Search>` is re-injected as a slim right-aligned strip BELOW it. An Astro
 * island (`<Search>`) cannot be a child of a React island, so it sits beside —
 * not inside — the NavBar. `--sl-nav-height` is pinned in the chrome CSS to the
 * combined NavBar + search-strip height so fixed-header content offset is right.
 *
 * - `activePath` is the literal "/docs": NavBar does EXACT-match active
 *   detection, so the real `/docs/<page>` pathname would never light the Docs
 *   tab. The whole docs section is "Docs", so the literal is correct.
 * - `ghCount` is the SSR placeholder only; the `NavStars` island (PageFrame
 *   override) patches the live count on the client, same as the main site.
 * - Starlight's `<ThemeSelect>` / `<SocialIcons>` / `<LanguageSelect>` are
 *   dropped: the footer `ThemeToggle` is the single canonical theme control
 *   (see the ThemeSelect override + the PageFrame footer).
 */
import Search from '@astrojs/starlight/components/Search.astro'
import NavBar from '@ui/components/molecules/NavBar.tsx'
import { FALLBACK_GITHUB_STARS } from '../lib/docs-fallbacks'
---

<div class="docs-chrome">
  <NavBar client:idle activePath="/docs" ghCount={FALLBACK_GITHUB_STARS} />
  {/* Pagefind search is enabled site-wide (docs.astro.config.mjs pagefind:true). */}
  <div class="docs-search-strip print:hidden">
    <Search />
  </div>
</div>
