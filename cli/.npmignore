# What lands in the tarball is the inverse of this list. At W1 the package is
# a placeholder: only package.json, README.md, and LICENSE need to ship.
# Real source ships W4+ when Track C lands the TypeScript CLI.

# Local / scratch
.local/
node_modules/
.DS_Store
Thumbs.db

# Source / build artifacts (no real source at W1; explicit allowlist below)
src/
dist/
build/
*.tsbuildinfo
.tsconfig*.json
vitest.config.*
.eslintrc.*
.biomerc.*

# Tests / fixtures
tests/
test/
__tests__/
*.test.*
*.spec.*

# Tooling configs
.github/
.vscode/
biome.json
tsconfig.json
.editorconfig
.gitignore
.gitattributes
