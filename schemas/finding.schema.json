{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://saferskills.ai/schemas/finding.schema.json",
  "title": "Finding",
  "description": "A single rule fire on a scanned artifact. Hashed-only evidence (matchedContentSha256) — never raw scanned content per .claude/rules/security.md § Scan-trace transparency. 5-tier severity; 5-axis sub_score; shadow/active status per rule lifecycle.",
  "x-postgresql-tablename": "findings",
  "x-postgresql-indexes": [
    { "name": "idx_findings_scan_id", "columns": ["scan_id"] },
    { "name": "idx_findings_rule_id", "columns": ["rule_id"] },
    { "name": "idx_findings_sub_score_severity", "columns": ["sub_score", "severity"] }
  ],
  "x-postgresql-extra-columns": [
    { "name": "created_at", "type": "timestamp", "nullable": false, "default": "now()" },
    { "name": "updated_at", "type": "timestamp", "nullable": false, "default": "now()" }
  ],
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "scanId",
    "ruleId",
    "severity",
    "subScore",
    "penalty",
    "statusAtScan",
    "filePath",
    "lineStart",
    "matchedContentSha256",
    "remediationLink",
    "rubricVersion"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "x-primary-key": true,
      "x-postgresql-default": "gen_random_uuid()",
      "description": "Server-assigned UUID (gen_random_uuid())."
    },
    "scanId": {
      "type": "string",
      "format": "uuid",
      "x-foreign-key": { "table": "scans", "column": "id", "ondelete": "CASCADE" },
      "description": "FK to parent scan."
    },
    "ruleId": {
      "type": "string",
      "pattern": "^SS-(MCP|SKILL|RULES|HOOKS|PLUGIN)-[A-Z][A-Z0-9-]*-\\d{2}$",
      "description": "Format `SS-<CATEGORY>-<NAME>-NN` per naming-conventions.md."
    },
    "severity": {
      "type": "string",
      "enum": ["info", "low", "medium", "high", "critical"],
      "x-postgresql-enum-type": "severity",
      "description": "5-tier severity ladder. `info` carries weight 0."
    },
    "subScore": {
      "type": "string",
      "enum": ["security", "supply_chain", "maintenance", "transparency", "community"],
      "x-postgresql-enum-type": "sub_score",
      "description": "5-axis sub-score the rule contributes to."
    },
    "penalty": {
      "type": "integer",
      "minimum": 0,
      "maximum": 40,
      "x-postgresql-default": "0",
      "description": "Penalty applied to the sub-score for this finding. 0 for shadow rules and info-severity rules (advisory)."
    },
    "statusAtScan": {
      "type": "string",
      "enum": ["shadow", "active"],
      "x-postgresql-enum-type": "status_at_scan",
      "description": "Rule status at the moment of scan. Shadow findings record in trace but do not affect score."
    },
    "filePath": {
      "type": "string",
      "maxLength": 1024,
      "description": "Path within the scanned tarball (e.g. `tools/manifest.json`, `src/mcp/server.ts`)."
    },
    "lineStart": {
      "type": "integer",
      "minimum": 1,
      "description": "1-indexed line number of the match start."
    },
    "lineEnd": {
      "type": ["integer", "null"],
      "minimum": 1,
      "description": "1-indexed line number of the match end. Null for single-line matches."
    },
    "matchedContentSha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 of the matched substring. Never the raw content (hash-only per security.md)."
    },
    "remediationLink": {
      "type": "string",
      "format": "uri",
      "description": "Permalink to the rule's `rubric/<CATEGORY>/<NAME>-NN.md` at the rubricVersion SHA."
    },
    "rubricVersion": {
      "type": "string",
      "pattern": "^[a-f0-9]{7,40}$",
      "description": "Git SHA of rubric/ at scan time."
    }
  },
  "examples": [
    {
      "id": "018e7c8b-aaaa-7000-8000-000000000001",
      "scanId": "018e7c8b-9999-7000-8000-000000000001",
      "ruleId": "SS-MCP-POISON-UNICODE-TAG-01",
      "severity": "critical",
      "subScore": "security",
      "penalty": 35,
      "statusAtScan": "active",
      "filePath": "src/mcp/server.ts",
      "lineStart": 42,
      "lineEnd": 58,
      "matchedContentSha256": "5d41402abc4b2a76b9719d911017c592e3b0c44298fc1c149afbf4c8996fb924",
      "remediationLink": "https://github.com/OpenLatch/saferskills/blob/a1b2c3d/rubric/MCP/POISON-UNICODE-TAG-01.md",
      "rubricVersion": "a1b2c3d"
    }
  ]
}
