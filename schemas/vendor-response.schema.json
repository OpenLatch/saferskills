{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://saferskills.ai/schemas/vendor-response.schema.json",
  "title": "VendorResponse",
  "description": "Verified-vendor public response on a catalog item. Transparency over erasure — old versions retained; the latest version renders on the report page. Body is Markdown, 2000-char cap.",
  "x-postgresql-tablename": "vendor_responses",
  "x-postgresql-indexes": [
    { "name": "idx_vendor_responses_catalog_item_version_desc", "columns": ["catalog_item_id", "version"] }
  ],
  "x-postgresql-extra-columns": [
    { "name": "created_at", "type": "timestamp", "nullable": false, "default": "now()" }
  ],
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "catalogItemId",
    "vendorVerificationId",
    "bodyMarkdown",
    "submittedAt",
    "updatedAt",
    "version"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "x-primary-key": true,
      "x-postgresql-default": "gen_random_uuid()",
      "description": "Server-assigned UUID (gen_random_uuid())."
    },
    "catalogItemId": {
      "type": "string",
      "format": "uuid",
      "x-foreign-key": { "table": "catalog_items", "column": "id", "ondelete": "CASCADE" }
    },
    "vendorVerificationId": {
      "type": "string",
      "format": "uuid",
      "x-foreign-key": { "table": "vendor_verifications", "column": "id", "ondelete": "CASCADE" },
      "description": "FK to the verification that authorised this response."
    },
    "bodyMarkdown": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000,
      "x-postgresql-type": "TEXT",
      "description": "Markdown body. Server-rendered; safe-listed Markdown (CommonMark + tables, no raw HTML)."
    },
    "submittedAt": {
      "type": "string",
      "format": "date-time",
      "x-postgresql-default": "now()"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "x-postgresql-default": "now()"
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "x-postgresql-default": "1",
      "description": "Monotonic version per catalog item — old versions retained for the public audit trail."
    }
  },
  "examples": [
    {
      "id": "018e7c8b-cccc-7000-8000-000000000001",
      "catalogItemId": "018e7c8b-1234-7000-8000-000000000001",
      "vendorVerificationId": "018e7c8b-bbbb-7000-8000-000000000001",
      "bodyMarkdown": "The flagged Unicode characters at line 42 are intentional — they encode the tool's i18n marker. Documented in `docs/i18n.md`. We've added a comment to clarify.",
      "submittedAt": "2026-05-26T12:00:00Z",
      "updatedAt": "2026-05-26T12:00:00Z",
      "version": 1
    }
  ]
}
