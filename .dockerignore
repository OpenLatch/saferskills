# Dependencies — always reinstalled during Docker build. Use a recursive glob so
# EVERY package's node_modules is excluded (incl. ui/node_modules) — pnpm symlinks
# copied into the build context dangle in the container and break module resolution
# (e.g. rollup "failed to resolve cmdk" from ui/) on a local `docker build`.
node_modules
**/node_modules

# pnpm store (content-addressable cache — massive, never needed in Docker)
.pnpm-store
**/.pnpm-store

# Build artifacts
services/*/dist
webapp/dist

# Python cache and virtual environments
__pycache__
*.pyc
*.pyo
.venv
services/*/.venv

# Test output and coverage
coverage
.nyc_output
htmlcov
.pytest_cache

# Editor and OS artifacts
.DS_Store
Thumbs.db
*.swp
*.swo

# Git
.git
.gitignore

# Planning docs (not needed in containers)
.planning
.claude
.claude/worktrees/

# Ladle build artifacts and story source (not needed in prod images)
ui/.ladle/
ui/stories/
ui/docs/

# Test artifacts
webapp/coverage/
webapp/.vitest/

# Playwright browser binaries
.playwright-cli
**/.playwright-cli

# Local dev config
.local

# Logs
*.log
